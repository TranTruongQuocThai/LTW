@model Daylifood.ViewModels.Seller.ProductEditViewModel

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="product-editor-card shadow-2xl border-0 rounded-5 overflow-hidden animate-slide-up">
    <div class="card-header-premium p-4">
        <div class="d-flex align-items-center">
            <div class="icon-box-md bg-soft-orange text-orange me-3">
                <i class="bi bi-egg-fried"></i>
            </div>
            <div>
                <h5 class="fw-bold text-dark-blue mb-0">Thông tin món ăn</h5>
                <p class="x-small text-muted mb-0">Bạn hãy điền đầy đủ để khách hàng dễ dàng đặt món nhé.</p>
            </div>
        </div>
    </div>

    <div class="card-body p-4 p-md-5 bg-white">
        <div class="form-group-modern mb-4">
            <label asp-for="Name" class="label-modern">TÊN MÓN ĂN <span class="text-danger">*</span></label>
            <div class="input-wrapper">
                <i class="bi bi-fonts"></i>
                <input asp-for="Name" class="input-modern" placeholder="Ví dụ: Cơm Tấm Sườn Bì Chả..." />
            </div>
            <span asp-validation-for="Name" class="text-danger-custom"></span>
        </div>

        <div class="form-group-modern mb-4">
            <label asp-for="Description" class="label-modern">MÔ TẢ CHI TIẾT</label>
            <div class="input-wrapper align-items-start py-2">
                <i class="bi bi-chat-left-text mt-2"></i>
                <textarea asp-for="Description" class="input-modern" rows="3" placeholder="Nguyên liệu, hương vị đặc biệt của món..."></textarea>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group-modern mb-4">
                    <label asp-for="CategoryId" class="label-modern">PHÂN LOẠI</label>
                    <div class="input-wrapper">
                        <i class="bi bi-grid"></i>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="input-modern select-clean">
                        </select>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="form-group-modern mb-4">
                    <label asp-for="Price" class="label-modern">GIÁ BÁN (VNĐ)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-currency-dollar"></i>
                        <input asp-for="Price" class="input-modern" type="number" step="1000" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger-custom"></span>
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="form-group-modern mb-4">
                    <label asp-for="Stock" class="label-modern">CÒN LẠI</label>
                    <div class="input-wrapper">
                        <i class="bi bi-archive"></i>
                        <input asp-for="Stock" class="input-modern" type="number" />
                    </div>
                    <span asp-validation-for="Stock" class="text-danger-custom"></span>
                </div>
            </div>
        </div>

        <div class="form-group-modern mb-4">
            <label asp-for="ImageUrl" class="label-modern">LINK HÌNH ẢNH MÓN ĂN</label>
            <div class="input-wrapper">
                <i class="bi bi-image"></i>
                <input asp-for="ImageUrl" class="input-modern" placeholder="https://..." />
            </div>
            <p class="x-small text-muted mt-2 ms-1"><i class="bi bi-lightbulb me-1 text-orange"></i> Mẹo: Hình ảnh đẹp giúp món ăn của bạn hấp dẫn hơn 50% đó!</p>
        </div>

        <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-light-soft border border-dashed mt-4">
            <div class="d-flex align-items-center">
                <div class="icon-box-sm bg-soft-emerald text-emerald me-3">
                    <i class="bi bi-eye"></i>
                </div>
                <div>
                    <label asp-for="IsActive" class="fw-bold text-dark-blue small mb-0 d-block">Hiển thị trên thực đơn</label>
                    <span class="x-small text-muted">Nếu tắt, món ăn sẽ tạm ẩn với khách hàng.</span>
                </div>
            </div>
            <div class="form-check form-switch custom-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --dark-blue: #0f172a;
        --orange: #ff7e5f;
        --emerald: #10b981;
        --soft-orange: #fff1ed;
        --soft-emerald: #ecfdf5;
        --bg-modern: #f8fafc;
    }

    .fw-800 { font-weight: 800; }
    .text-dark-blue { color: var(--dark-blue); }
    .text-orange { color: var(--orange); }
    .text-emerald { color: var(--emerald); }

    /* Card & Header */
    .product-editor-card { background: white; border: 1px solid #f1f5f9; }
    .card-header-premium { background: #fcfcfc; border-bottom: 1px dashed #e2e8f0; }
    .icon-box-md { width: 45px; height: 45px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
    .icon-box-sm { width: 35px; height: 35px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .bg-soft-orange { background: var(--soft-orange); }
    .bg-soft-emerald { background: var(--soft-emerald); }

    /* Modern Inputs */
    .label-modern { font-size: 0.7rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; margin-left: 5px; margin-bottom: 8px; display: block; }
    .input-wrapper { display: flex; align-items: center; background: #f1f5f9; border: 2px solid transparent; border-radius: 18px; padding: 5px 20px; transition: all 0.3s; }
    .input-wrapper i { color: #94a3b8; margin-right: 15px; font-size: 1.1rem; }
    .input-modern { background: transparent; border: none; padding: 12px 0; width: 100%; outline: none; font-size: 0.95rem; color: var(--dark-blue); font-weight: 500; }
    .input-wrapper:focus-within { background: #fff; border-color: var(--orange); box-shadow: 0 10px 20px rgba(255, 126, 95, 0.08); }
    .input-wrapper:focus-within i { color: var(--orange); }

    .select-clean { cursor: pointer; }
    .bg-light-soft { background-color: #f8fafc; }

    /* Custom Switch */
    .custom-switch .form-check-input { width: 3rem; height: 1.5rem; cursor: pointer; }
    .custom-switch .form-check-input:checked { background-color: var(--emerald); border-color: var(--emerald); }

    /* Utilities */
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05); }
    .text-danger-custom { font-size: 0.7rem; color: #ef4444; margin-top: 5px; display: block; padding-left: 10px; font-weight: 600; }
    .x-small { font-size: 0.7rem; }
    
    /* Animation */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: fadeInUp 0.6s ease-out both; }
</style>