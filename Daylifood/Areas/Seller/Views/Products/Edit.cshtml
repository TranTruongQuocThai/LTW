@model Daylifood.ViewModels.Seller.ProductEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa món ăn";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="product-edit-wrapper py-5">
    <div class="container">
        
        <div class="row mb-5 animate-fade-in">
            <div class="col-lg-9 mx-auto">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-area="Seller" asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Kênh người bán</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Thực đơn</a></li>
                        <li class="breadcrumb-item active fw-bold text-orange" aria-current="page">Chỉnh sửa món</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div class="d-flex align-items-center">
                        <div class="back-circle me-3">
                            <a asp-action="Index" class="text-dark"><i class="bi bi-arrow-left"></i></a>
                        </div>
                        <div>
                            <h1 class="fw-800 text-dark-blue family-lexend mb-0">Cập nhật món ăn</h1>
                            <p class="text-muted mb-0">Bạn đang chỉnh sửa thông tin cho mã món: <span class="badge bg-soft-orange text-orange">#@Model.Id</span></p>
                        </div>
                    </div>
                    <div class="d-none d-md-block">
                        <span class="text-muted small italic"><i class="bi bi-clock-history me-1"></i> Cập nhật lần cuối: Vừa xong</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-9 mx-auto">
                <form asp-action="Edit" method="post" id="editProductForm">
                    @Html.AntiForgeryToken()
                    @* Quan trọng: Giữ lại ID ẩn để hệ thống biết sửa món nào *@
                    <input type="hidden" asp-for="Id" />

                    <partial name="_ProductForm" model="Model" />

                    <div class="d-flex flex-wrap gap-3 mt-5 animate-slide-up" style="animation-delay: 0.2s">
                        <button type="submit" class="btn btn-update-premium px-5 py-3 rounded-pill fw-bold shadow-orange">
                            CẬP NHẬT NGAY <i class="bi bi-arrow-right-short ms-1"></i>
                        </button>
                        <a asp-action="Index" class="btn btn-cancel-premium px-5 py-3 rounded-pill fw-bold text-decoration-none">
                            Hủy thay đổi
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-lg-9 mx-auto animate-fade-in" style="animation-delay: 0.4s">
                <div class="warning-banner-soft p-4 rounded-5 border-dashed-blue">
                    <div class="d-flex align-items-start">
                        <div class="icon-circle-sm bg-soft-blue text-primary me-3 mt-1">
                            <i class="bi bi-info-circle-fill"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark-blue mb-1">Lưu ý về thay đổi giá:</h6>
                            <p class="text-muted small mb-0">Việc thay đổi giá bán hoặc số lượng tồn kho sẽ có hiệu lực ngay lập tức trên trang chủ Daylifood. Bạn hãy kiểm tra kỹ trước khi nhấn cập nhật nhé!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --dark-blue: #0f172a;
        --orange: #ff7e5f;
        --orange-dark: #ff6b6b;
        --bg-soft: #f8fafc;
        --soft-blue: #eff6ff;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-soft); }
    .family-lexend { font-family: 'Lexend', sans-serif; }
    .fw-800 { font-weight: 800; }
    .text-orange { color: var(--orange); }

    /* Back Button */
    .back-circle {
        width: 45px; height: 45px;
        background: white;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: 0.3s;
    }
    .back-circle:hover { transform: translateX(-5px); background: var(--orange); }
    .back-circle:hover a { color: white !important; }

    /* Action Buttons */
    .btn-update-premium {
        background: linear-gradient(45deg, var(--orange), var(--orange-dark));
        color: white; border: none; transition: all 0.3s;
        min-width: 220px;
    }
    .btn-update-premium:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(255, 126, 95, 0.3); color: white; }

    .btn-cancel-premium {
        background: #fff; color: #64748b; border: 2px solid #e2e8f0; transition: 0.3s;
        min-width: 150px; text-align: center;
    }
    .btn-cancel-premium:hover { background: #f1f5f9; color: var(--dark-blue); border-color: #cbd5e1; }

    /* Warning Banner */
    .warning-banner-soft { background-color: var(--soft-blue); }
    .border-dashed-blue { border: 2px dashed rgba(59, 130, 246, 0.3); }
    .bg-soft-blue { background: #dbeafe; }
    .icon-circle-sm { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: fadeInUp 0.7s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }

    .breadcrumb-item + .breadcrumb-item::before { content: "›"; color: #cbd5e1; font-weight: bold; }
    .italic { font-style: italic; }
    .bg-soft-orange { background: #fff1ed; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Hiệu ứng Spinner khi cập nhật
        document.getElementById('editProductForm').addEventListener('submit', function() {
            if ($(this).valid()) {
                const btn = this.querySelector('button[type="submit"]');
                btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ĐANG CẬP NHẬT...`;
                btn.classList.add('disabled');
            }
        });
    </script>
}