@model Daylifood.ViewModels.Seller.ProductEditViewModel
@{
    ViewData["Title"] = "Thêm món ăn mới";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="product-create-wrapper py-5">
    <div class="container">
        
        <div class="row mb-5 animate-fade-in">
            <div class="col-lg-9 mx-auto">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-area="Seller" asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Kênh người bán</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Thực đơn</a></li>
                        <li class="breadcrumb-item active fw-bold text-orange" aria-current="page">Thêm món mới</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center">
                    <div class="back-circle me-3">
                        <a asp-action="Index" class="text-dark"><i class="bi bi-arrow-left"></i></a>
                    </div>
                    <div>
                        <h1 class="fw-800 text-dark-blue family-lexend mb-0">Thêm món ăn mới</h1>
                        <p class="text-muted mb-0">Bắt đầu giới thiệu hương vị đặc sắc của quán bạn đến khách hàng.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-9 mx-auto">
                <form asp-action="Create" method="post" id="createProductForm">
                    @Html.AntiForgeryToken()

                    <partial name="_ProductForm" model="Model" />

                    <div class="d-flex flex-wrap gap-3 mt-5 animate-slide-up" style="animation-delay: 0.3s">
                        <button type="submit" class="btn btn-save-premium px-5 py-3 rounded-pill fw-bold shadow-orange">
                            TẠO MÓN NGAY <i class="bi bi-plus-lg ms-1"></i>
                        </button>
                        <a asp-action="Index" class="btn btn-cancel-premium px-5 py-3 rounded-pill fw-bold text-decoration-none">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-lg-9 mx-auto animate-fade-in" style="animation-delay: 0.5s">
                <div class="info-banner-soft p-4 rounded-5 border-dashed-orange">
                    <div class="d-flex">
                        <i class="bi bi-stars text-orange fs-4 me-3"></i>
                        <div>
                            <h6 class="fw-bold text-dark-blue mb-1">Bạn có biết không?</h6>
                            <p class="text-muted small mb-0">Các món ăn có mô tả chi tiết và hình ảnh chất lượng cao thường có tỷ lệ chốt đơn cao hơn 40% so với thông thường đó!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --dark-blue: #0f172a;
        --orange: #ff7e5f;
        --orange-dark: #ff6b6b;
        --bg-soft: #f8fafc;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-soft); }
    .family-lexend { font-family: 'Lexend', sans-serif; }
    .fw-800 { font-weight: 800; }
    .text-orange { color: var(--orange); }

    /* Back Button */
    .back-circle {
        width: 45px; height: 45px;
        background: white;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: 0.3s;
    }
    .back-circle:hover { transform: translateX(-5px); background: var(--orange); }
    .back-circle:hover a { color: white !important; }

    /* Action Buttons */
    .btn-save-premium {
        background: linear-gradient(45deg, var(--orange), var(--orange-dark));
        color: white; border: none; transition: all 0.3s;
        min-width: 200px;
    }
    .btn-save-premium:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(255, 126, 95, 0.3); color: white; }

    .btn-cancel-premium {
        background: #fff; color: #64748b; border: 2px solid #e2e8f0; transition: 0.3s;
        min-width: 150px; text-align: center;
    }
    .btn-cancel-premium:hover { background: #f1f5f9; color: var(--dark-blue); border-color: #cbd5e1; }

    /* Info Banner */
    .info-banner-soft { background-color: #fff1ed; }
    .border-dashed-orange { border: 2px dashed rgba(255, 126, 95, 0.3); }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: fadeInUp 0.7s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }

    .breadcrumb-item + .breadcrumb-item::before { content: "›"; color: #cbd5e1; font-weight: bold; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Hiệu ứng Loading khi bấm tạo món
        document.getElementById('createProductForm').addEventListener('submit', function() {
            if ($(this).valid()) {
                const btn = this.querySelector('button[type="submit"]');
                btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ĐANG TẠO MÓN...`;
                btn.classList.add('disabled');
            }
        });
    </script>
}