@model Daylifood.Models.ShipperProfile
@{
    ViewData["Title"] = "Thay đổi khu vực hoạt động";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="shipper-area-wrapper py-5">
    <div class="container">
        
        <nav aria-label="breadcrumb" class="mb-4 animate-fade-in">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="Shipper" asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Bảng điều khiển</a></li>
                <li class="breadcrumb-item active fw-bold text-emerald" aria-current="page">Khu vực hoạt động</li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="area-settings-card shadow-2xl border-0 rounded-5 overflow-hidden animate-slide-up">
                    <div class="card-header-map p-4 text-center">
                        <div class="icon-circle-map mb-3 mx-auto">
                            <i class="bi bi-geo-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark-blue family-lexend mb-1">Đổi khu vực giao</h2>
                        <p class="text-muted small">Bạn hãy chọn quận/huyện mà bạn muốn nhận đơn hôm nay.</p>
                    </div>

                    <div class="card-body p-4 p-md-5 bg-white">
                        <form asp-action="SetServiceArea" method="post" id="areaForm">
                            @Html.AntiForgeryToken()
                            
                            <div class="current-area-pill mb-4 d-flex align-items-center justify-content-center gap-2">
                                <span class="x-small fw-bold text-muted text-uppercase">Vùng hiện tại:</span>
                                <span class="badge bg-soft-emerald text-emerald rounded-pill px-3">
                                    @(Model?.DeliveryArea?.Name ?? "Chưa thiết lập")
                                </span>
                            </div>

                            <div class="form-group-modern mb-4">
                                <label class="label-modern">CHỌN KHU VỰC MỚI</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-map"></i>
                                    <select name="deliveryAreaId" class="input-modern select-clean" asp-items="ViewBag.DeliveryAreas">
                                        <option value="">-- Vui lòng chọn một khu vực --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-grid gap-3 mt-5">
                                <button type="submit" class="btn btn-save-area py-3 fw-800 rounded-pill shadow-emerald">
                                    LƯU THAY ĐỔI <i class="bi bi-check-lg ms-1"></i>
                                </button>
                                <a asp-action="Index" class="btn btn-light-modern py-3 fw-bold rounded-pill text-decoration-none text-center">
                                    Hủy bỏ
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="mt-4 p-4 rounded-4 bg-soft-blue border-dashed-blue animate-fade-in" style="animation-delay: 0.3s">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-shield-check-fill text-primary me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold text-dark-blue small mb-1">Lưu ý cho bạn:</h6>
                            <p class="text-muted small mb-0">Sau khi đổi khu vực, bạn sẽ chỉ nhận được thông báo về các đơn hàng phát sinh trong vùng đó. Hãy chọn nơi bạn thuộc đường nhất nhé!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --emerald: #10b981;
        --emerald-dark: #059669;
        --dark-blue: #0f172a;
        --soft-bg: #f8fafc;
        --soft-emerald: #ecfdf5;
        --soft-blue: #eff6ff;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--soft-bg); }
    .family-lexend { font-family: 'Lexend', sans-serif; }
    .fw-800 { font-weight: 800; }
    .text-emerald { color: var(--emerald); }

    /* Card Styling */
    .area-settings-card { background: white; border: 1px solid #f1f5f9; }
    .card-header-map { background: #fcfcfc; border-bottom: 1px dashed #e2e8f0; }

    .icon-circle-map {
        width: 65px; height: 65px;
        background: var(--soft-emerald);
        color: var(--emerald);
        border-radius: 22px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.12);
    }

    /* Current Area Pill */
    .current-area-pill { background: #f8fafc; padding: 10px; border-radius: 15px; border: 1px solid #f1f5f9; }

    /* Modern Select Styling */
    .label-modern { font-size: 0.7rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; margin-left: 5px; margin-bottom: 8px; display: block; }
    .input-wrapper { display: flex; align-items: center; background: #f1f5f9; border: 2px solid transparent; border-radius: 18px; padding: 5px 20px; transition: all 0.3s; }
    .input-wrapper i { color: #94a3b8; margin-right: 15px; font-size: 1.1rem; }
    .input-modern { background: transparent; border: none; padding: 12px 0; width: 100%; outline: none; font-size: 1rem; color: var(--dark-blue); font-weight: 600; }
    .input-wrapper:focus-within { background: #fff; border-color: var(--emerald); box-shadow: 0 10px 20px rgba(16, 185, 129, 0.08); }
    .input-wrapper:focus-within i { color: var(--emerald); }

    .select-clean { cursor: pointer; }

    /* Buttons */
    .btn-save-area { background: linear-gradient(135deg, var(--emerald), var(--emerald-dark)); color: white; border: none; transition: 0.3s; }
    .btn-save-area:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(16, 185, 129, 0.3); color: white; }

    .btn-light-modern { background: #fff; color: #64748b; border: 1.5px solid #e2e8f0; transition: 0.3s; }
    .btn-light-modern:hover { background: #f8fafc; color: var(--dark-blue); border-color: #cbd5e1; }

    /* Utilities */
    .bg-soft-emerald { background-color: var(--soft-emerald); }
    .bg-soft-blue { background-color: var(--soft-blue); }
    .border-dashed-blue { border: 1px dashed #3b82f6; }
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05); }
    .x-small { font-size: 0.65rem; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: fadeInUp 0.6s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }
</style>

@section Scripts {
    <script>
        // Hiệu ứng Spinner khi bấm lưu
        document.getElementById('areaForm').addEventListener('submit', function() {
            const btn = this.querySelector('button[type="submit"]');
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ĐANG CẬP NHẬT...`;
            btn.classList.add('disabled');
        });
    </script>
}