@model List<Daylifood.Models.Order>
@using Daylifood.Models
@{
    ViewData["Title"] = "Hành trình giao hàng";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="shipper-active-wrapper py-4">
    <div class="container">
        
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 animate-fade-in">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a asp-area="Shipper" asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Bảng điều khiển</a></li>
                        <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">Đơn đang giao</li>
                    </ol>
                </nav>
                <h1 class="fw-bold text-dark-blue family-lexend mb-0">Hành trình của bạn</h1>
                <p class="text-muted small">Bạn đang phụ trách <span class="badge bg-soft-primary text-primary">@Model.Count đơn hàng</span> ngay lúc này.</p>
            </div>
            
            <div class="d-none d-md-block">
                <div class="delivery-status-pill shadow-sm">
                    <i class="bi bi-bicycle me-2 pulse-blue"></i> Đang di chuyển
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-delivery-state text-center py-5 rounded-5 bg-white shadow-sm border border-dashed animate-up">
                <div class="illustration-container mb-4">
                    <i class="bi bi-box-seam text-muted opacity-25" style="font-size: 5rem;"></i>
                </div>
                <h4 class="fw-bold text-dark-blue">Bạn chưa có đơn nào đang giao</h4>
                <p class="text-muted">Hãy quay lại "Sảnh chờ đơn" để nhận thêm đơn mới và bắt đầu hành trình nhé!</p>
                <a asp-action="AvailableOrders" class="btn btn-primary rounded-pill px-5 py-2 mt-2 fw-bold shadow">ĐI TÌM ĐƠN NGAY</a>
            </div>
        }
        else
        {
            <div class="active-orders-stack">
                @foreach (var o in Model)
                {
                    <div class="order-tracking-card mb-4 animate-up shadow-sm">
                        <div class="tracking-sidebar"></div>
                        
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div class="d-flex align-items-center">
                                    <div class="order-id-hex me-3">#@o.Id</div>
                                    <div>
                                        <div class="x-small text-muted fw-bold">THANH TOÁN</div>
                                        <div class="fw-800 text-primary fs-5">@o.TotalPrice.ToString("N0") <small>đ</small></div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <a class="btn-detail-link" asp-action="OrderDetail" asp-route-id="@o.Id">
                                        Xem chi tiết <i class="bi bi-arrow-right-short"></i>
                                    </a>
                                </div>
                            </div>

                            <div class="route-map-box p-4 rounded-4 bg-light-soft mb-4 border border-light">
                                <div class="route-point start mb-4">
                                    <div class="route-icon"><i class="bi bi-shop-window"></i></div>
                                    <div class="route-text">
                                        <div class="x-small text-muted fw-bold">ĐIỂM LẤY HÀNG</div>
                                        <div class="fw-bold text-dark-blue small">Cửa hàng đối tác DayliFood</div>
                                    </div>
                                </div>
                                
                                <div class="route-connector"></div>

                                <div class="route-point end">
                                    <div class="route-icon bg-soft-danger text-danger"><i class="bi bi-geo-alt-fill"></i></div>
                                    <div class="route-text">
                                        <div class="x-small text-muted fw-bold">ĐIỂM GIAO ĐẾN</div>
                                        <div class="fw-bold text-dark-blue">@o.DeliveryArea.Name</div>
                                        <div class="small text-muted italic">@o.DeliveryAddress</div>
                                        <div class="mt-2 p-2 rounded-3 bg-white border small text-dark">
                                            <i class="bi bi-person-circle me-1 text-primary"></i> <strong>Khách:</strong> @o.Buyer.Email
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="items-summary-strip mb-4 d-flex align-items-center gap-2 overflow-auto">
                                <span class="x-small fw-bold text-muted text-uppercase me-2">GÓI HÀNG:</span>
                                @foreach (var i in o.OrderItems)
                                {
                                    <span class="badge bg-white text-dark-blue border rounded-pill small fw-600 px-3 py-2">
                                        @i.Product.Name <span class="text-primary ms-1">x@i.Quantity</span>
                                    </span>
                                }
                            </div>

                            <form asp-action="ConfirmDelivery" method="post" onsubmit="return confirmFinish('@o.Id')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@o.Id" />
                                <button type="submit" class="btn btn-finish-delivery w-100 py-3 rounded-pill fw-800 shadow-emerald animate-pulse">
                                    XÁC NHẬN ĐÃ GIAO TỚI NGƯỜI MUA <i class="bi bi-check-all ms-2 fs-5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    :root {
        --primary-blue: #3b82f6;
        --dark-blue: #0f172a;
        --emerald: #10b981;
        --soft-primary: #eff6ff;
        --soft-danger: #fef2f2;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
    .family-lexend { font-family: 'Lexend', sans-serif; }
    .fw-800 { font-weight: 800; }
    .fw-600 { font-weight: 600; }

    /* Header Status */
    .delivery-status-pill { background: white; padding: 10px 25px; border-radius: 50px; font-weight: 700; font-size: 0.85rem; color: var(--primary-blue); border: 1px solid #e2e8f0; }
    .pulse-blue { animation: pulse-blue-dot 2s infinite; }
    @@keyframes pulse-blue-dot { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.2); opacity: 0.5; } 100% { transform: scale(1); opacity: 1; } }

    /* Tracking Card */
    .order-tracking-card { background: white; border: none; border-radius: 40px; position: relative; overflow: hidden; transition: 0.3s; }
    .tracking-sidebar { position: absolute; left: 0; top: 0; bottom: 0; width: 10px; background: linear-gradient(to bottom, var(--primary-blue), #60a5fa); }
    
    .order-id-hex { background: var(--dark-blue); color: white; padding: 12px 20px; border-radius: 18px; font-weight: 800; font-size: 1rem; }
    .btn-detail-link { text-decoration: none; color: #94a3b8; font-weight: 700; font-size: 0.85rem; transition: 0.3s; }
    .btn-detail-link:hover { color: var(--primary-blue); transform: translateX(5px); }

    /* Route Visualizer */
    .route-map-box { position: relative; }
    .route-point { display: flex; align-items: flex-start; gap: 15px; position: relative; z-index: 2; }
    .route-icon { width: 36px; height: 36px; border-radius: 12px; background: #fff1ed; color: #ff7e5f; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    .route-connector { position: absolute; left: 41px; top: 50px; width: 2px; height: 30px; background: repeating-linear-gradient(to bottom, #e2e8f0, #e2e8f0 4px, transparent 4px, transparent 8px); z-index: 1; }

    /* Action Button */
    .btn-finish-delivery { background: linear-gradient(45deg, var(--emerald), #34d399); color: white; border: none; font-size: 1rem; letter-spacing: 0.5px; transition: 0.3s; }
    .btn-finish-delivery:hover { transform: scale(1.02); box-shadow: 0 15px 30px rgba(16, 185, 129, 0.3); color: white; }

    /* Pulse for Action */
    .animate-pulse { animation: pulse-emerald-glow 2s infinite; }
    @@keyframes pulse-emerald-glow { 0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); } 70% { box-shadow: 0 0 0 15px rgba(16, 185, 129, 0); } 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); } }

    /* Helpers */
    .bg-light-soft { background-color: #fcfdfe; }
    .bg-soft-primary { background-color: var(--soft-primary); }
    .bg-soft-danger { background-color: var(--soft-danger); }
    .shadow-emerald { box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2); }
    
    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeInUp 0.6s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }
    .x-small { font-size: 0.7rem; }
    .italic { font-style: italic; }
</style>

@section Scripts {
    <script>
        function confirmFinish(orderId) {
            return confirm(`Bác tài xác nhận là đã giao hàng THÀNH CÔNG đơn #${orderId} và nhận đủ tiền rồi chứ?`);
        }
    </script>
}