@model Daylifood.Models.Order
@using Daylifood.Models
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    var statusKey = Model.Status.ToString().ToLower();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lexend:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="order-detail-wrapper py-5">
    <div class="container">
        
        <div class="d-flex justify-content-between align-items-center mb-5 animate-fade-in">
            <div class="d-flex align-items-center">
                <a href="javascript:history.back()" class="btn-back-round me-3 shadow-sm">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h1 class="fw-800 text-dark-blue family-lexend mb-0">Đơn hàng #@Model.Id</h1>
                    <p class="text-muted small mb-0">Đặt lúc: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
            <div class="text-end">
                <span class="badge-status-lg @statusKey shadow-sm">
                    @Model.Status.ToVietnamese()
                </span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4 animate-up" style="animation-delay: 0.1s">
                <div class="info-card shadow-sm rounded-5 p-4 mb-4 bg-white border-0">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle bg-soft-primary text-primary me-3">
                            <i class="bi bi-person-badge-fill"></i>
                        </div>
                        <h5 class="fw-bold text-dark-blue mb-0">Khách hàng</h5>
                    </div>
                    <div class="small fw-600 text-dark mb-1">Email tài khoản:</div>
                    <div class="text-muted small mb-3">@Model.Buyer.Email</div>
                    <hr class="opacity-5">
                    <div class="small fw-600 text-dark mb-1">Phương thức:</div>
                    <div class="badge bg-soft-emerald text-emerald rounded-pill px-3">Tiền mặt (COD)</div>
                </div>

                <div class="info-card shadow-sm rounded-5 p-4 bg-white border-0">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle bg-soft-danger text-danger me-3">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h5 class="fw-bold text-dark-blue mb-0">Địa chỉ giao</h5>
                    </div>
                    <div class="small fw-800 text-dark-blue mb-1">@Model.DeliveryArea.Name</div>
                    <p class="text-muted small italic mb-0">@Model.DeliveryAddress</p>
                    
                    <div class="mt-4 p-3 rounded-4 bg-light-soft border border-dashed">
                        <p class="x-small text-muted mb-0">
                            <i class="bi bi-info-circle me-1"></i> 
                            Ghi chú: Bạn vui lòng kiểm tra kỹ địa chỉ trước khi xuất kho.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 animate-up" style="animation-delay: 0.2s">
                <div class="invoice-card shadow-2xl rounded-5 bg-white border-0 overflow-hidden">
                    <div class="card-header bg-dark-blue p-4 text-white">
                        <h5 class="fw-bold mb-0"><i class="bi bi-receipt me-2"></i>Chi tiết món ăn</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3 text-uppercase ls-1">Sản phẩm</th>
                                        <th class="py-3 text-uppercase ls-1 text-center">SL</th>
                                        <th class="py-3 text-uppercase ls-1 text-end">Đơn giá</th>
                                        <th class="pe-4 py-3 text-uppercase ls-1 text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var i in Model.OrderItems)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark-blue">@i.Product.Name</div>
                                                <div class="x-small text-muted">ID: #P-@i.ProductId</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-light text-dark fw-bold rounded-pill px-3">x @i.Quantity</span>
                                            </td>
                                            <td class="text-end text-muted small">
                                                @i.Price.ToString("N0") đ
                                            </td>
                                            <td class="pe-4 text-end">
                                                <span class="fw-bold text-dark-blue">@((i.Price * i.Quantity).ToString("N0")) đ</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-light p-4 border-0">
                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Tạm tính:</span>
                                    <span class="fw-bold small">@Model.TotalPrice.ToString("N0") đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-secondary border-opacity-10">
                                    <span class="text-muted small">Phí vận chuyển:</span>
                                    <span class="fw-bold text-success small">Free</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-800 text-dark-blue">TỔNG CỘNG:</span>
                                    <span class="fs-3 fw-800 text-primary">@Model.TotalPrice.ToString("N0") <small class="fs-6">đ</small></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button class="btn btn-outline-dark rounded-pill px-4 fw-bold" onclick="window.print()">
                        <i class="bi bi-printer me-2"></i>In hóa đơn
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --dark-blue: #0f172a;
        --primary-blue: #3b82f6;
        --emerald: #10b981;
        --orange: #ff7e5f;
        --bg-soft: #f8fafc;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-soft); }
    .family-lexend { font-family: 'Lexend', sans-serif; }
    .fw-800 { font-weight: 800; }
    .text-dark-blue { color: var(--dark-blue); }
    .bg-dark-blue { background-color: var(--dark-blue); }
    .text-emerald { color: var(--emerald); }
    .ls-1 { letter-spacing: 1px; font-size: 0.7rem; font-weight: 800; color: #94a3b8; }

    /* Buttons & Icons */
    .btn-back-round { width: 45px; height: 45px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--dark-blue); text-decoration: none; transition: 0.3s; }
    .btn-back-round:hover { background: var(--dark-blue); color: white; transform: translateX(-5px); }

    .icon-circle { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
    .bg-soft-primary { background: #eff6ff; }
    .bg-soft-danger { background: #fef2f2; }
    .bg-soft-emerald { background: #ecfdf5; }

    /* Badges */
    .badge-status-lg { padding: 10px 25px; border-radius: 50px; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .badge-status-lg.pending { background: #fef3c7; color: #b45309; }
    .badge-status-lg.processing { background: #dbeafe; color: #1d4ed8; }
    .badge-status-lg.completed { background: #dcfce7; color: #15803d; }
    .badge-status-lg.cancelled { background: #fee2e2; color: #b91c1c; }

    /* Cards */
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08); }
    .table thead th { border: none; }
    .bg-light-soft { background-color: #fcfdfe; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeInUp 0.6s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }
    .x-small { font-size: 0.7rem; }
    .italic { font-style: italic; }

    @@media print {
        .btn-back-round, .navbar, .btn-outline-dark, .breadcrumb { display: none !important; }
        .order-detail-wrapper { padding: 0 !important; }
        .invoice-card { box-shadow: none !important; border: 1px solid #eee !important; }
    }
</style>