<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bác Tài DayliFood</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Lexend:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --shipper-emerald: #10b981;
            --shipper-emerald-dark: #065f46;
            --shipper-navy: #0f172a;
            --shipper-accent: #34d399;
            --bg-soft: #f8fafc;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--bg-soft);
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar: Tối giản & Hiện đại */
        .shipper-navbar {
            background: linear-gradient(135deg, var(--shipper-navy) 0%, #1e293b 100%) !important;
            padding: 0.7rem 1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-bottom: 3px solid var(--shipper-emerald);
        }

        .navbar-brand {
            font-family: 'Lexend', sans-serif;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(to right, #fff, var(--shipper-accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Nav Links: Dạng thẻ (Pills) */
        .nav-link-shipper {
            color: rgba(255,255,255,0.7) !important;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            padding: 0.6rem 1rem !important;
            margin: 0 0.2rem;
            border-radius: 12px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-link-shipper:hover {
            color: #fff !important;
            background: rgba(255,255,255,0.1);
        }

        .nav-link-shipper.active {
            color: #fff !important;
            background: var(--shipper-emerald) !important;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

        /* User Profile & Actions */
        .user-action-box {
            background: rgba(255,255,255,0.05);
            padding: 5px 15px;
            border-radius: 50px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-logout-shipper {
            color: #fbbf24 !important;
            font-weight: 700;
            text-decoration: none;
            font-size: 0.8rem;
            transition: 0.3s;
        }
        .btn-logout-shipper:hover { opacity: 0.8; color: #f59e0b !important; }

        /* Alert Notifications */
        .shipper-toast {
            border: none;
            border-radius: 20px;
            padding: 1rem 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            animation: slideUp 0.4s ease-out;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        @@keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        /* Main Content Container */
        .shipper-main-content {
            flex: 1;
            padding-top: 2rem;
            animation: fadeIn 0.5s ease-in;
        }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        footer {
            background: white;
            padding: 1.5rem 0;
            border-top: 1px solid #e2e8f0;
            color: #64748b;
            font-size: 0.8rem;
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark shipper-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="Shipper" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bicycle me-2"></i>DAYLIFOOD <span class="fw-light opacity-75">SHIPPER</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#shipperNav">
                    <i class="bi bi-grid-3x3-gap-fill fs-3 text-emerald"></i>
                </button>

                <div class="collapse navbar-collapse" id="shipperNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link-shipper @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" 
                               asp-area="Shipper" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Tổng quan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-shipper @(ViewContext.RouteData.Values["Action"]?.ToString() == "AvailableOrders" ? "active" : "")" 
                               asp-area="Shipper" asp-controller="Home" asp-action="AvailableOrders">
                                <i class="bi bi-megaphone"></i> Đơn nhận ngay
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-shipper @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyDeliveries" ? "active" : "")" 
                               asp-area="Shipper" asp-controller="Home" asp-action="MyDeliveries">
                                <i class="bi bi-truck"></i> Đang giao
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-shipper @(ViewContext.RouteData.Values["Action"]?.ToString() == "SetServiceArea" ? "active" : "")" 
                               asp-area="Shipper" asp-controller="Home" asp-action="SetServiceArea">
                                <i class="bi bi-geo-alt"></i> Khu vực
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <a class="text-white-50 text-decoration-none small d-none d-xl-block" asp-area="" asp-controller="Home" asp-action="Index">
                            Vào Cửa hàng <i class="bi bi-shop ms-1"></i>
                        </a>
                        
                        <div class="user-action-box d-flex align-items-center gap-3">
                            <div class="small text-white-50 d-none d-md-block">Bác tài</div>
                            <div class="vr bg-white opacity-25" style="height: 15px;"></div>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn p-0 btn-logout-shipper shadow-none border-0">Đăng xuất</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container shipper-main-content">
        <div class="alert-wrapper">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success shipper-toast mb-4">
                    <i class="bi bi-check-circle-fill fs-4 text-emerald"></i>
                    <div class="flex-grow-1 fw-bold">@TempData["Message"]</div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shipper-toast mb-4">
                    <i class="bi bi-exclamation-octagon-fill fs-4"></i>
                    <div class="flex-grow-1 fw-bold">@TempData["Error"]</div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center">
        <div class="container">
            <p class="mb-1 fw-bold text-dark">DAYLIFOOD SHIPPER LOGISTICS</p>
            <p class="mb-0 italic x-small">Hệ thống vận hành dành riêng cho đối tác vận chuyển &copy; 2026</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Tự động ẩn thông báo sau 4 giây
        $(document).ready(function() {
            setTimeout(function() {
                $(".shipper-toast").fadeOut('slow');
            }, 4000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>