@{
    ViewData["Title"] = "Bảng điều khiển tổng quan";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lexend:wght@600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="dashboard-wrapper py-4">
    <div class="container-fluid px-lg-5">
        
        <div class="row mb-5 align-items-center animate-fade-in">
            <div class="col-md-8">
                <h2 class="fw-800 text-dark-blue family-jakarta mb-1">Trung tâm điều hành Daylifood</h2>
                <p class="text-muted mb-0">Chào bạn! Đây là những gì đang diễn ra với hệ thống của bạn hôm nay.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="current-date-pill shadow-sm">
                    <i class="bi bi-calendar3 me-2"></i>
                    <span id="live-clock">Đang tải...</span>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-xl-3 col-sm-6 animate-up" style="animation-delay: 0.1s">
                <div class="stat-card-premium card-blue h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="stat-icon-bg"><i class="bi bi-bag-heart-fill"></i></div>
                            <span class="badge-growth">+12% <i class="bi bi-arrow-up-short"></i></span>
                        </div>
                        <h6 class="text-white text-opacity-75 fw-bold ls-1 small">TỔNG ĐƠN HÀNG</h6>
                        <h2 class="display-5 fw-800 text-white mb-0 counter" data-target="@ViewBag.OrderCount">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6 animate-up" style="animation-delay: 0.2s">
                <div class="stat-card-premium card-orange h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="stat-icon-bg"><i class="bi bi-egg-fried"></i></div>
                        </div>
                        <h6 class="text-white text-opacity-75 fw-bold ls-1 small">MÓN ĂN ĐANG BÁN</h6>
                        <h2 class="display-5 fw-800 text-white mb-0 counter" data-target="@ViewBag.ProductCount">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6 animate-up" style="animation-delay: 0.3s">
                <div class="stat-card-premium card-emerald h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="stat-icon-bg"><i class="bi bi-shop-window"></i></div>
                        </div>
                        <h6 class="text-white text-opacity-75 fw-bold ls-1 small">ĐỐI TÁC CỬA HÀNG</h6>
                        <h2 class="display-5 fw-800 text-white mb-0 counter" data-target="@ViewBag.StoreCount">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6 animate-up" style="animation-delay: 0.4s">
                <div class="stat-card-premium card-dark h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="stat-icon-bg"><i class="bi bi-shield-lock-fill"></i></div>
                            <span class="badge bg-danger rounded-pill pulse-badge">@(ViewBag.PendingSellerApps + ViewBag.PendingShipperApps) MỚI</span>
                        </div>
                        <h6 class="text-white text-opacity-75 fw-bold ls-1 small mb-3">ĐƠN ĐĂNG KÝ ĐANG CHỜ</h6>
                        <div class="d-flex gap-3 text-white">
                            <div>
                                <small class="d-block opacity-75">Sellers</small>
                                <span class="fw-bold fs-5">@ViewBag.PendingSellerApps</span>
                            </div>
                            <div class="vr opacity-25"></div>
                            <div>
                                <small class="d-block opacity-75">Shippers</small>
                                <span class="fw-bold fs-5">@ViewBag.PendingShipperApps</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8 animate-slide-up">
                <div class="welcome-banner p-5 rounded-5 shadow-sm text-white h-100 position-relative overflow-hidden">
                    <div class="position-relative z-2">
                        <h3 class="fw-bold mb-3">Bạn có đơn đăng ký cần duyệt!</h3>
                        <p class="opacity-75 mb-4" style="max-width: 500px;">Các đối tác tiềm năng đang mong muốn gia nhập hệ thống Daylifood. Hãy xem xét hồ sơ của họ ngay để mở rộng quy mô kinh doanh nhé.</p>
                        <a class="btn btn-white-premium px-5 py-3 rounded-pill fw-800 shadow" asp-area="Admin" asp-controller="Applications" asp-action="Index">
                            ĐI TỚI DUYỆT ĐƠN <i class="bi bi-arrow-right-short ms-2"></i>
                        </a>
                    </div>
                    <div class="banner-illustration d-none d-md-block">
                        <i class="bi bi-bicycle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 animate-slide-up" style="animation-delay: 0.2s">
                <div class="card border-0 shadow-sm rounded-5 p-4 h-100 bg-white">
                    <h5 class="fw-bold text-dark-blue mb-4">Lối tắt quản lý</h5>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Categories" asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 d-flex align-items-center rounded-4">
                            <div class="icon-sm-box bg-soft-orange me-3"><i class="bi bi-grid"></i></div>
                            <span class="fw-semibold">Danh mục món ăn</span>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </a>
                        <a asp-controller="DeliveryAreas" asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 d-flex align-items-center rounded-4 mt-2">
                            <div class="icon-sm-box bg-soft-emerald me-3"><i class="bi bi-geo-alt"></i></div>
                            <span class="fw-semibold">Khu vực giao hàng</span>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action border-0 py-3 d-flex align-items-center rounded-4 mt-2">
                            <div class="icon-sm-box bg-soft-primary me-3"><i class="bi bi-people"></i></div>
                            <span class="fw-semibold">Quản lý người dùng</span>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --emerald: #10b981;
        --orange: #ff7e5f;
        --blue: #3b82f6;
        --dark-navy: #1e293b;
        --soft-bg: #f8fafc;
    }

    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--soft-bg); }
    .family-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }

    /* Custom Header Pill */
    .current-date-pill { background: white; padding: 10px 25px; border-radius: 50px; display: inline-flex; align-items: center; color: var(--dark-navy); font-weight: 700; border: 1px solid #f1f5f9; }

    /* Premium Stat Cards */
    .stat-card-premium { border-radius: 35px; border: none; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; overflow: hidden; }
    .stat-card-premium:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    
    .card-blue { background: linear-gradient(135deg, #4f46e5, #3b82f6); }
    .card-orange { background: linear-gradient(135deg, #f59e0b, #ff7e5f); }
    .card-emerald { background: linear-gradient(135deg, #059669, #10b981); }
    .card-dark { background: var(--dark-navy); }

    .stat-icon-bg { width: 50px; height: 50px; background: rgba(255,255,255,0.2); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: white; backdrop-filter: blur(5px); }
    .badge-growth { background: rgba(255,255,255,0.2); color: white; padding: 5px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; }

    /* Welcome Banner */
    .welcome-banner { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); }
    .banner-illustration { position: absolute; right: -20px; bottom: -30px; font-size: 15rem; color: rgba(255,255,255,0.05); transform: rotate(-15deg); }
    .btn-white-premium { background: white; color: var(--dark-navy); border: none; transition: 0.3s; }
    .btn-white-premium:hover { background: #f1f5f9; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

    /* List Group Custom */
    .icon-sm-box { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .bg-soft-orange { background: #fff1ed; color: var(--orange); }
    .bg-soft-emerald { background: #ecfdf5; color: var(--emerald); }
    .bg-soft-primary { background: #eff6ff; color: var(--blue); }

    .pulse-badge { animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.4); } 70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(220, 38, 38, 0); } 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); } }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeInUp 0.7s ease-out both; }
    .animate-slide-up { animation: fadeInUp 0.6s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 1. Hiệu ứng chạy số (Counter Animation)
            const counters = document.querySelectorAll('.counter');
            counters.forEach(counter => {
                const target = +counter.getAttribute('data-target');
                const updateCount = () => {
                    const count = +counter.innerText;
                    const speed = 200; // Tốc độ chạy số
                    const inc = target / speed;
                    if (count < target) {
                        counter.innerText = Math.ceil(count + inc);
                        setTimeout(updateCount, 1);
                    } else {
                        counter.innerText = target;
                    }
                };
                updateCount();
            });

            // 2. Đồng hồ thời gian thực
            function updateClock() {
                const now = new Date();
                const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
                document.getElementById('live-clock').innerText = now.toLocaleDateString('vi-VN', options);
            }
            setInterval(updateClock, 1000);
            updateClock();
        });
    </script>
}