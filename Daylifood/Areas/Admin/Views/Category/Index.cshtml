@model List<Daylifood.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600;700&family=Comfortaa:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="admin-wrapper py-4">
    <div class="container">
        
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 animate-fade-in">
            <div>
                <h1 class="fw-bold text-dark-blue family-comfortaa mb-1">Danh mục sản phẩm</h1>
                <p class="text-muted small mb-0">Bạn đang quản lý <span class="badge bg-soft-orange text-orange">@Model.Count nhóm món ăn</span></p>
            </div>
            <div class="mt-3 mt-md-0">
                <a class="btn btn-food-gradient rounded-pill px-4 py-2 fw-bold shadow-orange" asp-action="Create">
                    <i class="bi bi-plus-lg me-2"></i>THÊM DANH MỤC
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-2xl rounded-5 overflow-hidden animate-slide-up">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase ls-1">Mã số</th>
                            <th class="py-3 text-uppercase ls-1">Tên danh mục</th>
                            <th class="py-3 text-uppercase ls-1 text-center">Trạng thái</th>
                            <th class="pe-4 py-3 text-uppercase ls-1 text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr class="category-row">
                                <td class="ps-4">
                                    <span class="text-muted fw-bold">#@c.Id</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="cat-icon-mini me-3">
                                            <i class="bi bi-bookmark-star-fill"></i>
                                        </div>
                                        <span class="fw-bold text-dark-blue fs-6">@c.Name</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-soft-emerald text-emerald px-3">Hoạt động</span>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a class="btn btn-action edit" asp-action="Edit" asp-route-id="@c.Id" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirmDelete('@c.Name');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button type="submit" class="btn btn-action delete" title="Xóa">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="opacity-25 mb-3">
                                        <i class="bi bi-folder-x display-1"></i>
                                    </div>
                                    <h5 class="text-muted">Chưa có danh mục nào được tạo.</h5>
                                    <p class="small text-muted">Bạn hãy nhấn "Thêm danh mục" để bắt đầu nhé!</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4 text-center">
            <p class="text-muted x-small italic">
                <i class="bi bi-info-circle me-1"></i> Mẹo: Danh mục rõ ràng giúp khách hàng của Daylifood đặt món nhanh hơn 30%.
            </p>
        </div>
    </div>
</div>

<style>
    :root {
        --food-orange: #ff7e5f;
        --food-orange-dark: #ff6b6b;
        --dark-blue: #1e293b;
        --emerald: #10b981;
        --soft-bg: #fdfaf8;
        --soft-orange: #fff1ed;
        --soft-emerald: #ecfdf5;
    }

    body { font-family: 'Lexend', sans-serif; background-color: var(--soft-bg); }
    .family-comfortaa { font-family: 'Comfortaa', cursive; }
    .text-orange { color: var(--food-orange); }
    .text-emerald { color: var(--emerald); }
    .ls-1 { letter-spacing: 1px; font-size: 0.7rem; font-weight: 800; color: #94a3b8; }

    /* Table Container */
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08); }
    .table thead th { border: none; }
    .category-row { transition: all 0.2s; }
    .category-row:hover { background-color: #fcfcfc; }

    /* Category Mini Icon */
    .cat-icon-mini {
        width: 35px; height: 35px;
        background: var(--soft-orange);
        color: var(--food-orange);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
    }

    /* Status Badges */
    .bg-soft-orange { background-color: var(--soft-orange); }
    .bg-soft-emerald { background-color: var(--soft-emerald); }

    /* Action Buttons */
    .btn-action {
        width: 38px; height: 38px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        border: none; transition: all 0.3s;
        background: #f1f5f9;
        color: #64748b;
    }
    .btn-action.edit:hover { background-color: #e0f2fe; color: #0284c7; transform: translateY(-2px); }
    .btn-action.delete:hover { background-color: #fee2e2; color: #ef4444; transform: translateY(-2px); }

    /* Main Add Button */
    .btn-food-gradient {
        background: linear-gradient(45deg, var(--food-orange), var(--food-orange-dark));
        color: white; border: none; transition: all 0.3s;
    }
    .btn-food-gradient:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(255, 107, 107, 0.3); color: white; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: fadeInUp 0.6s ease-out both; }
    .animate-fade-in { animation: fadeInUp 0.4s ease-out both; }

    .x-small { font-size: 0.75rem; }
    .italic { font-style: italic; }
</style>

@section Scripts {
    <script>
        function confirmDelete(name) {
            return confirm(`Bạn có chắc chắn muốn XÓA danh mục "${name}" chứ? Thao tác này không thể hoàn tác đâu!`);
        }
    </script>
}