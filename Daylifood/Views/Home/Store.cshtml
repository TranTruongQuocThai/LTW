@model List<Daylifood.Models.Product>
@{
    var store = ViewBag.Store as Daylifood.Models.Store;
    var categories = ViewBag.Categories as List<Daylifood.Models.Category> ?? new();
    var selected = ViewBag.SelectedCategoryId as int?;
    var searchQ = ViewBag.SearchQuery as string;
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=Comfortaa:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

@if (store == null)
{
    <div class="container py-5 text-center">
        <div class="p-5 bg-white rounded-5 shadow-sm">
            <i class="bi bi-shop-window display-1 text-muted opacity-25"></i>
            <h3 class="mt-3 fw-bold">Ôi! Không tìm thấy quán</h3>
            <a asp-action="Stores" class="btn btn-food-orange rounded-pill px-4 mt-3">Quay lại danh sách</a>
        </div>
    </div>
}
else
{
    ViewData["Title"] = store.Name;

    <div class="store-detail-wrapper">
        <div class="store-hero shadow-sm">
            <div class="store-hero-overlay"></div>
            <div class="container position-relative z-3">
                <nav aria-label="breadcrumb" class="pt-4 animate-up">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-action="Stores" class="text-white opacity-75 text-decoration-none">Danh sách quán</a></li>
                        <li class="breadcrumb-item active text-white fw-bold" aria-current="page">@store.Name</li>
                    </ol>
                </nav>

                <div class="store-header-box p-4 p-md-5 rounded-5 mt-4 glass-card animate-up">
                    <div class="row align-items-center">
                        <div class="col-md-auto text-center text-md-start mb-3 mb-md-0">
                            <div class="store-logo-circle shadow-lg">
                                <i class="bi bi-shop"></i>
                            </div>
                        </div>
                        <div class="col-md">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="badge rounded-pill bg-success px-3 py-2"><i class="bi bi-patch-check-fill me-1"></i> Đối tác uy tín</span>
                                <span class="badge rounded-pill bg-white text-dark px-3 py-2"><i class="bi bi-star-fill text-warning me-1"></i> 4.9 (500+)</span>
                            </div>
                            <h1 class="display-5 fw-bold text-white family-comfortaa mb-2">@store.Name</h1>
                            <div class="store-meta text-white opacity-90 d-flex flex-wrap gap-3">
                                @if (!string.IsNullOrWhiteSpace(store.Address))
                                {
                                    <span><i class="bi bi-geo-alt-fill me-1 text-warning"></i> @store.Address</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(store.Phone))
                                {
                                    <span><i class="bi bi-telephone-fill me-1 text-warning"></i> @store.Phone</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(store.Description))
                            {
                                <p class="text-white opacity-75 mt-3 mb-0 fst-italic">"@store.Description"</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mt-5">
            <div class="row g-4 align-items-center mb-5 animate-up">
                <div class="col-lg-4">
                    <form method="get" asp-action="Store" asp-route-id="@store.Id" class="search-box-modern shadow-sm">
                        <i class="bi bi-search text-muted ms-3"></i>
                        <input type="search" name="q" value="@searchQ" class="form-control border-0 bg-transparent shadow-none" placeholder="Tìm món ngon tại quán..." />
                        <button type="submit" class="btn btn-food-orange rounded-pill px-3 me-1">Tìm</button>
                    </form>
                </div>
                <div class="col-lg-8">
                    <div class="category-scroller-modern">
                        <a class="cat-pill-modern @(selected == null ? "active" : "")"
                           asp-action="Store" asp-route-id="@store.Id" asp-route-q="@searchQ">Tất cả</a>
                        @foreach (var c in categories)
                        {
                            <a class="cat-pill-modern @(selected == c.Id ? "active" : "")"
                               asp-action="Store" asp-route-id="@store.Id" asp-route-categoryId="@c.Id" asp-route-q="@searchQ">@c.Name</a>
                        }
                    </div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 rounded-5 bg-white shadow-sm border border-dashed animate-up">
                    <i class="bi bi-search display-3 text-muted opacity-25"></i>
                    <p class="mt-3 text-muted fs-5">
                        @if (!string.IsNullOrWhiteSpace(searchQ))
                        {
                            <span>Không tìm thấy món nào phù hợp với “@searchQ” tại quán.</span>
                        }
                        else
                        {
                            <span>Quán đang chuẩn bị cập nhật thực đơn mới. Quay lại sau nhé bạn!</span>
                        }
                    </p>
                    <a asp-action="Store" asp-route-id="@store.Id" class="btn btn-link text-orange fw-bold">Xóa bộ lọc</a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="product-grid">
                    @foreach (var p in Model)
                    {
                        <div class="col product-item">
                            <div class="food-card-modern shadow-sm h-100 border-0">
                                <div class="img-zoom-box">
                                    <img src="@(p.ImageUrl ?? "/images/placeholder.svg")" class="card-img-top" alt="@p.Name" />
                                    <div class="card-price-tag">@p.Price.ToString("N0") <small>₫</small></div>
                                </div>
                                <div class="card-body p-3">
                                    <small class="text-orange fw-bold text-uppercase ls-1">@p.Category.Name</small>
                                    <h6 class="fw-bold text-dark-blue mt-1 mb-3 text-truncate">@p.Name</h6>
                                    <div class="d-grid">
                                        <a class="btn btn-outline-food py-2 rounded-pill fw-bold" asp-action="Detail" asp-route-id="@p.Id">
                                            Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    :root {
        --food-orange: #ff7e5f;
        --food-orange-dark: #ff6b6b;
        --dark-blue: #1e293b;
        --bg-warm: #fcfcfc;
    }

    body { font-family: 'Lexend', sans-serif; background-color: var(--bg-warm); }
    .family-comfortaa { font-family: 'Comfortaa', cursive; }
    .text-orange { color: var(--food-orange); }
    .ls-1 { letter-spacing: 1px; font-size: 0.65rem; }

    /* Hero Banner */
    .store-hero {
        background: url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?ixlib=rb-1.2.1&auto=format&fit=crop&w=1500&q=80') center/cover;
        min-height: 400px;
        position: relative;
        border-radius: 0 0 50px 50px;
        display: flex; align-items: center;
    }
    .store-hero-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(to bottom, rgba(30, 41, 59, 0.4), rgba(30, 41, 59, 0.8));
        border-radius: 0 0 50px 50px;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .store-logo-circle {
        width: 100px; height: 100px;
        background: white; border-radius: 30px;
        display: flex; align-items: center; justify-content: center;
        font-size: 3rem; color: var(--food-orange);
    }

    /* Search & Category */
    .search-box-modern {
        background: white; border-radius: 50px;
        display: flex; align-items: center; padding: 5px;
        border: 2px solid transparent; transition: all 0.3s;
    }
    .search-box-modern:focus-within { border-color: var(--food-orange); }

    .category-scroller-modern {
        display: flex; gap: 10px; overflow-x: auto;
        padding-bottom: 5px; scrollbar-width: none;
    }
    .category-scroller-modern::-webkit-scrollbar { display: none; }

    .cat-pill-modern {
        white-space: nowrap; padding: 10px 25px;
        background: white; border-radius: 50px;
        color: var(--dark-blue); text-decoration: none;
        font-weight: 600; font-size: 0.9rem;
        transition: all 0.3s; border: 1px solid #f1f5f9;
    }
    .cat-pill-modern.active {
        background: var(--food-orange); color: white; border-color: transparent;
        box-shadow: 0 10px 20px rgba(255, 126, 95, 0.2);
    }

    /* Food Card */
    .food-card-modern {
        background: white; border-radius: 30px;
        overflow: hidden; transition: all 0.4s;
    }
    .food-card-modern:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.08) !important; }

    .img-zoom-box { position: relative; height: 200px; overflow: hidden; }
    .img-zoom-box img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
    .food-card-modern:hover .img-zoom-box img { transform: scale(1.1); }

    .card-price-tag {
        position: absolute; bottom: 15px; left: 15px;
        background: var(--food-orange); color: white;
        padding: 5px 15px; border-radius: 50px;
        font-weight: 800; font-size: 1rem;
        box-shadow: 0 5px 15px rgba(255, 126, 95, 0.3);
    }

    .btn-food-orange { background: var(--food-orange); color: white; border: none; }
    .btn-food-orange:hover { background: var(--food-orange-dark); color: white; }

    .btn-outline-food { border: 2px solid #f1f5f9; color: var(--dark-blue); transition: all 0.3s; }
    .btn-outline-food:hover { border-color: var(--food-orange); color: var(--food-orange); }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeInUp 0.7s ease-out; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const productItems = document.querySelectorAll('.product-item');
            
            // Staggered Fade-in Animation cho danh sách món ăn
            productItems.forEach((item, index) => {
                item.style.opacity = '0';
                item.style.transform = 'translateY(20px)';
                item.style.transition = 'all 0.5s ease-out';
                
                setTimeout(() => {
                    item.style.opacity = '1';
                    item.style.transform = 'translateY(0)';
                }, 100 * (index % 8)); // Delay từng món cho hiệu ứng mượt
            });

            // Hiệu ứng Parallax nhẹ cho Banner
            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                const hero = document.querySelector('.store-hero');
                if(hero) {
                    hero.style.backgroundPositionY = (scrolled * 0.4) + 'px';
                }
            });
        });
    </script>
}