@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=Comfortaa:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="privacy-wrapper py-5">
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>

    <div class="container position-relative">
        <div class="text-center mb-5 animate-fade-up">
            <div class="privacy-icon-shield mb-4">
                <div class="shield-glow"></div>
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1 class="fw-bold text-dark-blue family-comfortaa display-5">@ViewData["Title"]</h1>
            <p class="text-muted mx-auto lead" style="max-width: 700px;">
                Chào bạn! Tại <strong>Daylifood</strong>, chúng tôi coi dữ liệu của bạn quý giá như công thức bí truyền của một đầu bếp. Sự riêng tư của bạn là ưu tiên hàng đầu của chúng tôi.
            </p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="accordion-modern shadow-2xl rounded-5 overflow-hidden bg-white" id="privacyAccordion">
                    
                    <div class="accordion-item-modern border-bottom">
                        <div class="accordion-trigger p-4 d-flex align-items-center" data-bs-toggle="collapse" data-bs-target="#collectInfo">
                            <div class="icon-box-sm bg-soft-blue me-3">
                                <i class="bi bi-database-fill-add"></i>
                            </div>
                            <span class="fw-bold fs-5 text-dark-blue">1. Chúng tôi thu thập thông tin gì?</span>
                            <i class="bi bi-chevron-down ms-auto arrow-icon"></i>
                        </div>
                        <div id="collectInfo" class="collapse show" data-bs-parent="#privacyAccordion">
                            <div class="accordion-content px-5 pb-4 text-secondary lh-lg">
                                Để mang đến cho bạn những bữa ăn ngon nhất, Daylifood cần ghi nhớ:
                                <ul class="custom-list mt-3">
                                    <li><i class="bi bi-check2-circle me-2 text-emerald"></i><strong>Hồ sơ cá nhân:</strong> Tên, email, số điện thoại để chúng tôi biết bạn là ai.</li>
                                    <li><i class="bi bi-check2-circle me-2 text-emerald"></i><strong>Tọa độ giao hàng:</strong> Địa chỉ chính xác để Shipper không làm đồ ăn của bạn bị nguội.</li>
                                    <li><i class="bi bi-check2-circle me-2 text-emerald"></i><strong>Gu ẩm thực:</strong> Lịch sử đặt món giúp chúng tôi gợi ý những món "đúng bài" cho bạn.</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item-modern border-bottom">
                        <div class="accordion-trigger p-4 d-flex align-items-center collapsed" data-bs-toggle="collapse" data-bs-target="#useInfo">
                            <div class="icon-box-sm bg-soft-orange me-3">
                                <i class="bi bi-magic"></i>
                            </div>
                            <span class="fw-bold fs-5 text-dark-blue">2. Cách chúng tôi sử dụng thông tin</span>
                            <i class="bi bi-chevron-down ms-auto arrow-icon"></i>
                        </div>
                        <div id="useInfo" class="collapse" data-bs-parent="#privacyAccordion">
                            <div class="accordion-content px-5 pb-4 text-secondary lh-lg">
                                Thông tin của bạn được sử dụng một cách tinh tế để:
                                <ul class="custom-list mt-3">
                                    <li>Vận hành hệ thống, xử lý đơn hàng và giao hàng siêu tốc.</li>
                                    <li>Gửi các "món quà" bất ngờ qua thông báo khuyến mãi.</li>
                                    <li>Liên tục nâng cấp giao diện Daylifood mượt mà hơn mỗi ngày.</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item-modern">
                        <div class="accordion-trigger p-4 d-flex align-items-center collapsed" data-bs-toggle="collapse" data-bs-target="#securityInfo">
                            <div class="icon-box-sm bg-soft-success me-3">
                                <i class="bi bi-fingerprint"></i>
                            </div>
                            <span class="fw-bold fs-5 text-dark-blue">3. Cam kết bảo mật dữ liệu</span>
                            <i class="bi bi-chevron-down ms-auto arrow-icon"></i>
                        </div>
                        <div id="securityInfo" class="collapse" data-bs-parent="#privacyAccordion">
                            <div class="accordion-content px-5 pb-4 text-secondary lh-lg">
                                <p>Chúng tôi bao bọc dữ liệu của bạn bằng các lớp mã hóa tiêu chuẩn quân đội. Daylifood cam kết <strong>không bao giờ</strong> "bán rẻ" sự tin tưởng của bạn cho bên thứ ba vì bất kỳ mục đích thương mại nào.</p>
                                <div class="alert alert-emerald border-0 rounded-4 mt-3">
                                    <i class="bi bi-patch-check-fill me-2"></i> Dữ liệu của bạn, quyền kiểm soát của bạn.
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="contact-footer mt-5 p-5 text-center rounded-5 shadow-sm border border-white">
                    <h4 class="fw-bold text-dark-blue mb-3">Bạn còn băn khoăn điều gì?</h4>
                    <p class="text-muted small mb-4">Đừng ngần ngại, đội ngũ bảo vệ dữ liệu của Daylifood luôn sẵn sàng giải đáp.</p>
                    <a href="mailto:privacy@daylifood.com" class="btn btn-emerald-luxury rounded-pill px-5 py-3 fw-bold">
                        <i class="bi bi-envelope-heart me-2"></i> LIÊN HỆ BỘ PHẬN BẢO MẬT
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --emerald: #10b981;
        --emerald-dark: #059669;
        --dark-blue: #1e293b;
        --soft-blue: #eff6ff;
        --soft-orange: #fff7ed;
        --soft-success: #ecfdf5;
    }

    body { font-family: 'Lexend', sans-serif; background-color: #fcfcfc; }
    .family-comfortaa { font-family: 'Comfortaa', cursive; }
    .text-dark-blue { color: var(--dark-blue); }
    .text-emerald { color: var(--emerald); }

    .privacy-wrapper { position: relative; overflow: hidden; min-height: 100vh; }

    /* Background Shapes */
    .bg-shape { position: absolute; border-radius: 50%; filter: blur(80px); z-index: 0; opacity: 0.4; }
    .shape-1 { width: 300px; height: 300px; background: #dcfce7; top: -100px; right: -50px; }
    .shape-2 { width: 400px; height: 400px; background: #eff6ff; bottom: -150px; left: -100px; }

    /* Privacy Icon */
    .privacy-icon-shield {
        position: relative;
        display: inline-flex;
        width: 100px; height: 100px;
        background: white;
        border-radius: 35px;
        align-items: center; justify-content: center;
        font-size: 3rem; color: var(--emerald);
        box-shadow: 0 20px 40px rgba(16, 185, 129, 0.15);
    }
    .shield-glow {
        position: absolute; width: 100%; height: 100%;
        background: var(--emerald); filter: blur(30px);
        opacity: 0.2; z-index: -1;
    }

    /* Accordion Modern */
    .accordion-modern { border: 1px solid rgba(0,0,0,0.05); }
    .accordion-trigger { cursor: pointer; transition: all 0.3s; }
    .accordion-trigger:hover { background: #fafafa; }
    .accordion-trigger:not(.collapsed) .arrow-icon { transform: rotate(180deg); color: var(--emerald); }
    .accordion-trigger:not(.collapsed) { background: #fff; border-left: 5px solid var(--emerald); }

    .icon-box-sm {
        width: 45px; height: 45px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }
    .bg-soft-blue { background: #e0f2fe; color: #0369a1; }
    .bg-soft-orange { background: #ffedd5; color: #c2410c; }
    .bg-soft-success { background: #dcfce7; color: #15803d; }

    .arrow-icon { transition: transform 0.3s; color: #94a3b8; }

    .custom-list { list-style: none; padding-left: 0; }
    .custom-list li { margin-bottom: 12px; }

    .alert-emerald { background: var(--soft-success); color: var(--emerald-dark); font-weight: 500; }

    /* Footer Card */
    .contact-footer {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 2px solid #fff;
    }

    .btn-emerald-luxury {
        background: linear-gradient(135deg, var(--emerald), var(--emerald-dark));
        color: white; border: none; transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
    }
    .btn-emerald-luxury:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(16, 185, 129, 0.4); color: white; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-up { animation: fadeInUp 0.8s ease-out; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const triggers = document.querySelectorAll('.accordion-trigger');
            
            // JavaScript để tạo hiệu ứng hover mượt mà hơn cho accordion
            triggers.forEach(trigger => {
                trigger.addEventListener('click', function() {
                    // Xử lý logic nếu cần thêm hiệu ứng đặc biệt khi đóng/mở
                    setTimeout(() => {
                        this.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }, 350);
                });
            });
        });
    </script>
}