@model List<Daylifood.Models.Store>
@{
    ViewData["Title"] = "Danh sách quán ngon";
    var searchQ = ViewBag.SearchQuery as string;
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=Comfortaa:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="stores-page-wrapper py-5">
    <div class="container text-center mb-5 animate-up">
        <span class="badge rounded-pill bg-soft-orange text-orange px-3 py-2 mb-3">KHÁM PHÁ CỬA HÀNG</span>
        <h1 class="display-5 fw-bold family-comfortaa text-dark-blue">Tinh Hoa Ẩm Thực Địa Phương</h1>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Bạn ơi, cùng tìm kiếm những quán ăn uy tín và chất lượng nhất quanh bạn nhé!
        </p>
    </div>

    <div class="container mb-5 animate-up" style="animation-delay: 0.1s;">
        <form class="row justify-content-center" method="get" asp-action="Stores" role="search">
            <div class="col-lg-6 col-md-8">
                <div class="search-premium shadow-sm">
                    <i class="bi bi-search text-muted ms-3"></i>
                    <input type="search" name="q" value="@searchQ" class="form-control border-0 bg-transparent shadow-none" 
                           placeholder="Tìm tên quán, địa chỉ hoặc món ăn..." autocomplete="off" />
                    <button type="submit" class="btn btn-food-orange rounded-pill px-4 me-1">Tìm kiếm</button>
                </div>
            </div>
        </form>
    </div>

    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5 rounded-5 bg-white shadow-sm border border-dashed animate-up">
                <div class="empty-icon mb-3">
                    <i class="bi bi-shop-window display-1 opacity-10"></i>
                </div>
                <h4 class="fw-bold text-dark-blue">Hic! Daylifood chưa tìm thấy quán này</h4>
                <p class="text-muted">Bạn thử tìm với tên khác hoặc xem tất cả các quán hiện có nhé.</p>
                <a asp-action="Stores" class="btn btn-outline-orange rounded-pill px-4">Xem tất cả quán</a>
            </div>
        }
        else
        {
            <div class="row g-4" id="store-grid">
                @foreach (var s in Model)
                {
                    <div class="col-md-6 col-lg-4 store-item">
                        <a asp-action="Store" asp-route-id="@s.Id" class="text-decoration-none">
                            <div class="store-card-luxury h-100 shadow-sm border-0 bg-white">
                                <div class="store-cover">
                                    <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" alt="Store Cover">
                                    <div class="store-status-badge">
                                        <span class="badge rounded-pill bg-success shadow-sm">Đang mở cửa</span>
                                    </div>
                                    <div class="store-rating">
                                        <i class="bi bi-star-fill text-warning"></i> 4.8
                                    </div>
                                </div>

                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="store-avatar-box me-3">
                                            <i class="bi bi-shop"></i>
                                        </div>
                                        <div class="overflow-hidden">
                                            <h5 class="store-name text-truncate mb-0">@s.Name</h5>
                                            <span class="text-orange small fw-600 ls-1">ĐỐI TÁC DAYLIFOOD</span>
                                        </div>
                                    </div>

                                    <div class="store-info-list">
                                        @if (!string.IsNullOrWhiteSpace(s.Address))
                                        {
                                            <div class="info-line">
                                                <i class="bi bi-geo-alt-fill text-muted"></i>
                                                <span class="text-secondary text-truncate">@s.Address</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(s.Phone))
                                        {
                                            <div class="info-line">
                                                <i class="bi bi-telephone-fill text-muted"></i>
                                                <span class="text-secondary">@s.Phone</span>
                                            </div>
                                        }
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(s.Description))
                                    {
                                        <p class="store-desc mt-3">
                                            @(s.Description.Length > 90 ? s.Description[..90] + "..." : s.Description)
                                        </p>
                                    }

                                    <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                                        <span class="view-menu-link">Xem thực đơn <i class="bi bi-arrow-right ms-1"></i></span>
                                        <div class="delivery-time small text-muted">
                                            <i class="bi bi-clock me-1"></i> 15-20 phút
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    :root {
        --food-orange: #ff7e5f;
        --food-orange-dark: #ff6b6b;
        --dark-blue: #1e293b;
        --bg-warm: #fcfcfc;
        --soft-orange: #fff1ed;
    }

    body { font-family: 'Lexend', sans-serif; background-color: var(--bg-warm); }
    .family-comfortaa { font-family: 'Comfortaa', cursive; }
    .text-orange { color: var(--food-orange); }
    .bg-soft-orange { background-color: var(--soft-orange); }
    .fw-600 { font-weight: 600; }
    .ls-1 { letter-spacing: 0.5px; }

    /* Search Premium */
    .search-premium {
        background: white;
        border-radius: 50px;
        display: flex;
        align-items: center;
        padding: 6px;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }
    .search-premium:focus-within {
        border-color: var(--food-orange);
        box-shadow: 0 15px 30px rgba(255, 126, 95, 0.1);
        transform: translateY(-2px);
    }
    .btn-food-orange {
        background: var(--food-orange);
        color: white; border: none;
        transition: all 0.3s;
    }
    .btn-food-orange:hover { background: var(--food-orange-dark); color: white; transform: scale(1.05); }

    /* Store Card Luxury */
    .store-card-luxury {
        border-radius: 35px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .store-card-luxury:hover {
        transform: translateY(-12px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.08) !important;
    }

    .store-cover {
        height: 160px;
        position: relative;
        overflow: hidden;
    }
    .store-cover img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }
    .store-card-luxury:hover .store-cover img { transform: scale(1.1); }

    .store-status-badge { position: absolute; top: 15px; left: 15px; }
    .store-rating {
        position: absolute; bottom: 15px; right: 15px;
        background: white; padding: 4px 12px; border-radius: 50px;
        font-weight: 700; font-size: 0.8rem; box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .store-avatar-box {
        width: 50px; height: 50px;
        background: var(--soft-orange);
        color: var(--food-orange);
        border-radius: 15px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
    }

    .store-name { font-weight: 700; color: var(--dark-blue); font-size: 1.15rem; }
    
    .info-line { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; font-size: 0.85rem; }
    .store-desc { font-size: 0.85rem; color: #64748b; line-height: 1.6; }

    .view-menu-link {
        color: var(--food-orange); font-weight: 700; font-size: 0.9rem;
        transition: all 0.3s;
    }
    .store-card-luxury:hover .view-menu-link { letter-spacing: 0.5px; }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeInUp 0.7s ease-out both; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const storeItems = document.querySelectorAll('.store-item');
            
            // JavaScript Reveal Animation: Hiện từng quán một theo trình tự (Staggered Effect)
            storeItems.forEach((item, index) => {
                item.style.opacity = '0';
                item.style.transform = 'translateY(30px)';
                item.style.transition = 'all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
                
                // Sử dụng Intersection Observer để chỉ hiện khi cuộn tới (tối ưu hiệu năng)
                const observer = new IntersectionObserver((entries) => {
                    if (entries[0].isIntersecting) {
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'translateY(0)';
                        }, index * 100); // Mỗi item cách nhau 0.1s
                        observer.unobserve(item);
                    }
                }, { threshold: 0.1 });
                
                observer.observe(item);
            });

            // Hiệu ứng Hover đặc biệt cho Search Bar
            const searchInput = document.querySelector('.search-premium input');
            searchInput.addEventListener('focus', () => {
                document.querySelector('.search-premium').classList.add('shadow-lg');
            });
            searchInput.addEventListener('blur', () => {
                document.querySelector('.search-premium').classList.remove('shadow-lg');
            });
        });
    </script>
}