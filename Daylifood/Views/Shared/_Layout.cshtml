<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DayliFood</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Pacifico&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        :root {
            --dayli-green: #10b981;
            --dayli-orange: #ff7e5f;
            --dayli-yellow: #ffb300;
            --dark-navy: #1e293b;
            --soft-bg: #fcfcfc;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--soft-bg);
            color: var(--dark-navy);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navbar Glassmorphism */
        .navbar {
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            background-color: rgba(255, 255, 255, 0.85) !important;
            border-bottom: 1px solid rgba(0,0,0,0.05) !important;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
        }

        .navbar-brand { 
            font-family: 'Pacifico', cursive;
            font-size: 1.8rem;
            background: linear-gradient(45deg, var(--dayli-green), var(--dayli-yellow));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Thanh tìm kiếm - Đã thu ngắn lại 300px theo ý bạn */
        .search-container { 
            position: relative; 
            max-width: 300px; /* Ngắn lại vừa xinh */
            width: 100%; 
        }

        .search-input-group {
            background: #f1f5f9;
            border-radius: 50px;
            padding: 2px 5px 2px 15px;
            transition: all 0.3s;
            border: 1px solid transparent;
        }

        .search-input-group:focus-within {
            background: #fff;
            border-color: var(--dayli-orange);
            box-shadow: 0 10px 25px rgba(255, 126, 95, 0.1);
        }

        .search-input-group input {
            border: none; background: transparent; padding: 8px 0;
            outline: none; font-size: 0.85rem; width: 100%;
        }

        /* Nav Links */
        .nav-link { 
            font-weight: 500; color: var(--dark-navy) !important; 
            padding: 0.5rem 1rem !important; border-radius: 12px; transition: all 0.2s;
        }
        .nav-link:hover { 
            color: var(--dayli-orange) !important; 
            background: rgba(255, 126, 95, 0.05);
        }

        /* User Avatar */
        .user-avatar {
            width: 38px; height: 38px;
            background: linear-gradient(45deg, var(--dayli-orange), var(--dayli-yellow));
            color: white; display: flex; align-items: center; justify-content: center;
            border-radius: 12px; font-weight: bold;
            box-shadow: 0 4px 10px rgba(255, 126, 95, 0.2);
        }

        /* Animations - Dùng @@ để tránh lỗi Razor */
        main { animation: fadeIn 0.5s ease-in; }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .footer-premium {
            background: #fff; border-top: 1px solid #f1f5f9;
            padding: 60px 0 30px; margin-top: auto;
        }

        .btn-warning {
            background-color: var(--dayli-orange) !important;
            border-color: var(--dayli-orange) !important;
            color: white !important;
        }

        /* Dropdown Menu Custom */
        .dropdown-menu {
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
            border-radius: 20px !important;
            padding: 10px !important;
        }

        /* Mobile */
        @@media (max-width: 991.98px) {
            .search-container { max-width: 100%; margin-bottom: 15px; }
            .navbar-collapse {
                background: white; padding: 20px;
                border-radius: 25px; margin-top: 10px;
                box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            }
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg py-2">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Intro">
                    Daylifood
                </a>

                <div class="d-none d-lg-flex flex-grow-1 justify-content-center px-4">
                    <form class="search-container" method="get" asp-area="" asp-controller="Home" asp-action="Index">
                        <div class="search-input-group d-flex align-items-center shadow-sm">
                            <i class="bi bi-search text-muted me-2"></i>
                            <input type="search" name="q" value="@Context.Request.Query["q"]" placeholder="Hôm nay bạn muốn ăn gì?" autocomplete="off" />
                            <button type="submit" class="btn btn-warning rounded-pill px-3 btn-sm fw-bold">Tìm</button>
                        </div>
                    </form>
                </div>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <i class="bi bi-list fs-2 text-dark"></i>
                </button>

                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Intro">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Thực đơn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Stores">Quán ngon</a>
                        </li>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("User") || User.IsInRole("Shipper"))
                            {
                                <li class="nav-item ms-lg-2">
                                    <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                        <i class="bi bi-bag-heart fs-5"></i>
                                        <span class="d-lg-none ms-2">Giỏ hàng</span>
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 py-2 py-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <a class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle shadow-none" href="#" role="button" data-bs-toggle="dropdown">
                                    <div class="user-avatar shadow-sm">@User.Identity.Name?[0].ToString().ToUpper()</div>
                                    <div class="d-none d-xl-block">
                                        <div class="text-dark fw-bold small">@User.Identity.Name</div>
                                        <div class="text-muted x-small">Thành viên</div>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg animate-fadeIn">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle me-2 text-primary"></i>Hồ sơ</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-controller="Order" asp-action="History"><i class="bi bi-clock-history me-2 text-success"></i>Đơn hàng</a></li>
                                    
                                    @if (User.IsInRole("Admin")) {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item rounded-3 py-2 text-danger fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-shield-lock me-2"></i>Admin Panel</a></li>
                                    }
                                    @if (User.IsInRole("Seller")) {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item rounded-3 py-2 text-info fw-bold" asp-area="Seller" asp-controller="Home" asp-action="Index"><i class="bi bi-shop-window me-2"></i>Kênh Người Bán</a></li>
                                    }
                                    @if (User.IsInRole("Shipper")) {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item rounded-3 py-2 text-primary fw-bold" asp-area="Shipper" asp-controller="Home" asp-action="Index"><i class="bi bi-truck me-2"></i>Khu vực Shipper</a></li>
                                    }
                                    
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item rounded-3 py-2 text-muted bg-transparent border-0 w-100 text-start">
                                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-link text-dark text-decoration-none fw-bold" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 mt-4">
        <main role="main" class="pb-3">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
                        <div>@TempData["Message"]</div>
                    </div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
                        <div>@TempData["Error"]</div>
                    </div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    @await Html.PartialAsync("_ChatbotWidget")

    <footer class="footer-premium">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-5">
                    <h3 class="navbar-brand p-0 mb-3 d-block">Daylifood</h3>
                    <p class="text-muted" style="max-width: 350px;">Mang trọn tinh hoa ẩm thực địa phương đến bàn ăn của bạn. Nhanh chóng, an toàn và tận tâm.</p>
                    <div class="d-flex gap-3 fs-4 mt-4">
                        <i class="bi bi-facebook text-primary"></i>
                        <i class="bi bi-instagram text-danger"></i>
                        <i class="bi bi-tiktok text-dark"></i>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="fw-bold mb-4 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Khám phá</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-action="Index" asp-controller="Home" class="text-muted text-decoration-none">Thực đơn đặc sắc</a></li>
                        <li class="mb-2"><a asp-action="Stores" asp-controller="Home" class="text-muted text-decoration-none">Danh sách quán</a></li>
                        <li class="mb-2"><a asp-action="Intro" asp-controller="Home" class="text-muted text-decoration-none">Về chúng tôi</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="fw-bold mb-4 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-action="Privacy" asp-controller="Home" class="text-muted text-decoration-none">Chính sách bảo mật</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Điều khoản sử dụng</a></li>
                    </ul>
                </div>
            </div>
            <div class="pt-5 mt-5 border-top text-center text-muted small">
                <p class="mb-0">© 2026 <strong>DayliFood</strong>. Được phát triển bởi <span class="text-success fw-bold">đội ngũ DayliFood</span>.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Hiệu ứng cuộn Navbar
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('py-1', 'shadow-sm');
            } else {
                navbar.classList.remove('py-1', 'shadow-sm');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>