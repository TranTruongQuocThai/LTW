@model RegisterViewModel
@{
    ViewData["Title"] = "Gia nhập Daylifood";
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=Pacifico&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="register-page-bg py-5">
    <div class="floating-element f-1"><i class="bi bi-heart-fill"></i></div>
    <div class="floating-element f-2"><i class="bi bi-star-fill"></i></div>
    <div class="floating-element f-3"><i class="bi bi-egg-fried"></i></div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-11">
                <div class="main-register-card border-0 shadow-2xl rounded-5 overflow-hidden bg-white">
                    <div class="row g-0">
                        
                        <div class="col-md-5 d-none d-md-block position-relative side-info-panel">
                            <div class="panel-overlay"></div>
                            <div class="panel-content p-5 text-white h-100 d-flex flex-column justify-content-between">
                                <div class="brand-area animate-fade-in">
                                    <h1 class="brand-logo-text mb-0">Daylifood</h1>
                                    <div class="badge rounded-pill bg-white text-orange fw-bold px-3 py-1 mt-2">Ăn ngon mỗi ngày</div>
                                </div>
                                
                                <div class="benefits-area mt-5">
                                    <h3 class="fw-bold mb-4">Gia nhập ngay để nhận:</h3>
                                    <div class="benefit-item mb-3">
                                        <div class="benefit-icon"><i class="bi bi-percent"></i></div>
                                        <span>Giảm 50% cho đơn hàng đầu tiên</span>
                                    </div>
                                    <div class="benefit-item mb-3">
                                        <div class="benefit-icon"><i class="bi bi-truck"></i></div>
                                        <span>Freeship mọi nẻo đường bán kính 3km</span>
                                    </div>
                                    <div class="benefit-item">
                                        <div class="benefit-icon"><i class="bi bi-gem"></i></div>
                                        <span>Tích điểm đổi quà cực "chill"</span>
                                    </div>
                                </div>

                                <div class="footer-quote mt-auto pt-4 border-top border-white border-opacity-25">
                                    <p class="small fst-italic">"Đồ ăn ngon là chìa khóa ngắn nhất mở cửa trái tim."</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-7 p-4 p-lg-5 bg-white">
                            <div class="text-start mb-4">
                                <h2 class="fw-bold text-dark-blue mb-1">Tạo tài khoản mới</h2>
                                <p class="text-muted small">Cùng bạn bắt đầu hành trình khám phá ẩm thực ngay nào!</p>
                            </div>

                            <form asp-action="Register" method="post" id="registerForm">
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="ModelOnly" class="alert alert-soft-danger py-2 small border-0 rounded-3 mb-4"></div>

                                <div class="row g-3">
                                    <div class="col-12">
                                        <div class="form-group-modern">
                                            <label asp-for="FullName" class="label-modern">HỌ VÀ TÊN</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-person"></i>
                                                <input asp-for="FullName" class="input-modern" placeholder="Nguyễn Văn A" />
                                            </div>
                                            <span asp-validation-for="FullName" class="text-danger-custom"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label asp-for="Email" class="label-modern">EMAIL</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-envelope"></i>
                                                <input asp-for="Email" class="input-modern" placeholder="duy@example.com" />
                                            </div>
                                            <span asp-validation-for="Email" class="text-danger-custom"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label asp-for="PhoneNumber" class="label-modern">SỐ ĐIỆN THOẠI</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-phone"></i>
                                                <input asp-for="PhoneNumber" class="input-modern" placeholder="0901234567" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-group-modern">
                                            <label asp-for="Address" class="label-modern">ĐỊA CHỈ GIAO HÀNG</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-geo-alt"></i>
                                                <input asp-for="Address" class="input-modern" placeholder="Số nhà, tên đường, quận..." />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label asp-for="Password" class="label-modern">MẬT KHẨU</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-lock"></i>
                                                <input asp-for="Password" type="password" id="passMain" class="input-modern" placeholder="••••••••" />
                                            </div>
                                            <div class="pw-strength mt-2">
                                                <div id="strength-bar" class="strength-bar"></div>
                                            </div>
                                            <span asp-validation-for="Password" class="text-danger-custom"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label asp-for="ConfirmPassword" class="label-modern">XÁC NHẬN</label>
                                            <div class="input-wrapper">
                                                <i class="bi bi-shield-check"></i>
                                                <input asp-for="ConfirmPassword" type="password" class="input-modern" placeholder="••••••••" />
                                            </div>
                                            <span asp-validation-for="ConfirmPassword" class="text-danger-custom"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-grid mt-5">
                                    <button type="submit" id="btnRegister" class="btn btn-food-gradient py-3 fw-bold rounded-pill shadow-orange">
                                        ĐĂNG KÝ NGAY <i class="bi bi-arrow-right-short ms-1"></i>
                                    </button>
                                </div>

                                <div class="text-center mt-4">
                                    <span class="text-muted small">Đã có tài khoản Daylifood?</span>
                                    <a asp-action="Login" class="text-orange fw-bold text-decoration-none ms-1 hover-link">Đăng nhập</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --food-orange: #ff7e5f;
        --food-red: #ff6b6b;
        --dark-blue: #1e293b;
        --bg-soft: #fff9f6;
    }

    body { font-family: 'Lexend', sans-serif; background: var(--bg-soft); overflow-x: hidden; }
    .brand-logo-text { font-family: 'Pacifico', cursive; font-size: 3rem; }
    .text-orange { color: var(--food-orange); }
    .text-dark-blue { color: var(--dark-blue); }

    .register-page-bg {
        min-height: 100vh;
        position: relative;
        background-image: radial-gradient(var(--food-orange) 0.5px, transparent 0.5px);
        background-size: 30px 30px;
    }

    .floating-element {
        position: absolute; color: var(--food-orange); opacity: 0.1;
        font-size: 2rem; z-index: 0; animation: float 6s infinite ease-in-out;
    }
    .f-1 { top: 10%; left: 5%; }
    .f-2 { bottom: 15%; right: 5%; animation-delay: 2s; }
    .f-3 { top: 40%; right: 10%; animation-delay: 4s; font-size: 3rem; }

    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(10deg); }
    }

    .side-info-panel {
        background: url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?ixlib=rb-1.2.1&auto=format&fit=crop&w=1000&q=80') center/cover;
    }
    .panel-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(255, 126, 95, 0.9) 0%, rgba(255, 107, 107, 0.9) 100%);
    }
    .panel-content { position: relative; z-index: 2; }

    .benefit-item {
        display: flex; align-items: center; background: rgba(255, 255, 255, 0.15);
        padding: 12px 15px; border-radius: 15px; backdrop-filter: blur(5px);
    }
    .benefit-icon {
        width: 35px; height: 35px; background: #fff; color: var(--food-orange);
        border-radius: 10px; display: flex; align-items: center; justify-content: center;
        margin-right: 15px; font-weight: bold;
    }

    .main-register-card { box-shadow: 0 30px 70px rgba(255, 126, 95, 0.15); border-radius: 40px !important; }

    .label-modern {
        font-size: 0.7rem; font-weight: 800; color: #94a3b8;
        letter-spacing: 1px; margin-left: 5px; margin-bottom: 8px; display: block;
    }

    .input-wrapper {
        display: flex; align-items: center; background: #f8fafc;
        border: 2px solid transparent; border-radius: 16px;
        padding: 4px 15px; transition: all 0.3s;
    }
    .input-wrapper i { color: #cbd5e1; margin-right: 12px; }
    .input-modern { background: transparent; border: none; padding: 10px 0; width: 100%; outline: none; font-size: 0.95rem; }

    .input-wrapper:focus-within { background: #fff; border-color: var(--food-orange); box-shadow: 0 8px 20px rgba(255, 126, 95, 0.1); }

    .pw-strength { height: 4px; width: 100%; background: #e2e8f0; border-radius: 2px; overflow: hidden; }
    .strength-bar { height: 100%; width: 0%; transition: all 0.4s; }

    .btn-food-gradient {
        background: linear-gradient(45deg, var(--food-orange), var(--food-red));
        color: white; border: none; letter-spacing: 1px; transition: all 0.3s;
    }
    .btn-food-gradient:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(255, 107, 107, 0.4); color: white; }

    .alert-soft-danger { background: #fee2e2; color: #ef4444; }
    .text-danger-custom { font-size: 0.7rem; color: #ef4444; margin-top: 4px; display: block; }
    .hover-link:hover { text-decoration: underline !important; }

    @@media (max-width: 768px) {
        .main-register-card { border-radius: 25px !important; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const passInput = document.getElementById('passMain');
            const strengthBar = document.getElementById('strength-bar');
            const btnRegister = document.getElementById('btnRegister');
            const form = document.getElementById('registerForm');

            // 1. Kiểm tra độ mạnh mật khẩu khi gõ
            passInput.addEventListener('input', function() {
                const val = this.value;
                let strength = 0;
                
                if (val.length > 5) strength += 25;
                if (val.match(/[A-Z]/)) strength += 25;
                if (val.match(/[0-9]/)) strength += 25;
                if (val.match(/[^A-Za-z0-9]/)) strength += 25;

                strengthBar.style.width = strength + '%';
                
                if (strength <= 25) strengthBar.style.backgroundColor = '#ef4444'; // Yếu - Đỏ
                else if (strength <= 50) strengthBar.style.backgroundColor = '#f59e0b'; // Trung bình - Cam
                else if (strength <= 75) strengthBar.style.backgroundColor = '#3b82f6'; // Khá - Xanh biển
                else strengthBar.style.backgroundColor = '#10b981'; // Mạnh - Xanh lá
            });

            // 2. Hiệu ứng Loading khi nhấn nút Đăng ký
            form.addEventListener('submit', function(e) {
                // Kiểm tra xem form có hợp lệ theo Client-side validation không
                if ($(this).valid()) {
                    btnRegister.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ĐANG XỬ LÝ...`;
                    btnRegister.classList.add('disabled');
                }
            });

            // 3. Hiệu ứng Focus cho Input Wrappers
            const wrappers = document.querySelectorAll('.input-wrapper');
            wrappers.forEach(w => {
                const input = w.querySelector('input');
                input.addEventListener('focus', () => {
                    w.querySelector('i').style.color = 'var(--food-orange)';
                });
                input.addEventListener('blur', () => {
                    w.querySelector('i').style.color = '#cbd5e1';
                });
            });
        });
    </script>
}