@model ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="profile-wrapper py-5">
    <div class="container mt-md-2">
        <div class="row g-4 justify-content-center">
            
            <div class="col-lg-7">
                <div class="main-profile-card shadow-sm border-0">
                    <div class="profile-cover"></div>
                    
                    <div class="card-body px-4 px-md-5 pb-5 position-relative">
                        <div class="avatar-wrapper" style="top: -170px !important; z-index: 10;">
                            <div class="avatar-circle shadow-lg" style="background: linear-gradient(135deg, #ff7e5f, #ff6b6b) !important; color: white !important; width: 130px !important; height: 130px !important; border: 7px solid #fff !important; border-radius: 40px !important;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="status-indicator online" style="width: 24px !important; height: 24px !important; border-width: 4px !important; bottom: 8px !important; right: 8px !important;"></div>
                        </div>

                        <div class="text-center mb-4" style="margin-top: 2rem;">
                            <h3 class="fw-bold text-dark mb-1">@Model.FullName</h3>
                            <p class="text-muted small">Thành viên thân thiết của Daylifood</p>
                        </div>

                        @if (TempData["Message"] != null)
                        {
                            <div class="alert alert-food-success d-flex align-items-center border-0 rounded-4 mb-4 fade show">
                                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                                <div>@TempData["Message"]</div>
                                <button type="button" class="btn-close ms-auto shadow-none" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form asp-action="Profile" method="post" id="profileForm">
                            @Html.AntiForgeryToken()
                            
                            <div class="row g-4">
                                <div class="col-12">
                                    <div class="form-group-custom">
                                        <label class="label-small">ĐỊA CHỈ EMAIL</label>
                                        <div class="input-readonly">
                                            <i class="bi bi-envelope-at me-2"></i> @Model.Email
                                            <span class="badge-lock"><i class="bi bi-lock-fill"></i></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-group-custom">
                                        <label asp-for="FullName" class="label-small">HỌ VÀ TÊN</label>
                                        <input asp-for="FullName" class="form-control-food" placeholder="Nhập tên của bạn" />
                                        <span asp-validation-for="FullName" class="text-danger-custom"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label asp-for="PhoneNumber" class="label-small">SỐ ĐIỆN THOẠI</label>
                                        <input asp-for="PhoneNumber" class="form-control-food" placeholder="09xx xxx xxx" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label asp-for="Address" class="label-small">ĐỊA CHỈ MẶC ĐỊNH</label>
                                        <input asp-for="Address" class="form-control-food" placeholder="Số nhà, tên đường..." />
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 text-center">
                                <button type="submit" id="btnUpdate" class="btn btn-save-profile py-3 px-5 shadow-orange">
                                    CẬP NHẬT HỒ SƠ <i class="bi bi-arrow-right-short ms-2"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="status-card shadow-sm mb-4 border-0">
                    <div class="card-body p-4">
                        <h6 class="fw-bold text-secondary mb-3 small">CẤP BẬC TÀI KHOẢN</h6>
                        <div class="d-flex flex-wrap gap-2">
                            @if (User.IsInRole("Admin")) { <span class="role-badge badge-admin">Quản trị viên</span> }
                            @if (User.IsInRole("Seller")) { <span class="role-badge badge-seller">Người bán</span> }
                            @if (User.IsInRole("Shipper")) { <span class="role-badge badge-shipper">Shipper</span> }
                            @if (User.IsInRole("User")) { <span class="role-badge badge-user">Khách hàng</span> }
                        </div>
                        
                        <hr class="my-4 opacity-25">
                        
                        <div class="reward-points d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-gift-fill text-orange fs-4 me-2"></i>
                                <span class="small fw-bold">Điểm tích lũy</span>
                            </div>
                            <span class="fw-bold text-orange">1.250 pts</span>
                        </div>
                    </div>
                </div>

                @if (User.IsInRole("User") && !User.IsInRole("Seller") && !User.IsInRole("Admin"))
                {
                    <div class="earn-card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-2">Kiếm thêm thu nhập?</h5>
                            <p class="text-muted small mb-4">Hãy trở thành đối tác cùng Daylifood để gia tăng thu nhập hàng tháng.</p>
                            
                            <div class="d-grid gap-3">
                                <a asp-action="ApplyAsSeller" class="btn-earn btn-earn-seller">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-box me-3"><i class="bi bi-shop"></i></div>
                                        <div class="text-start">
                                            <div class="fw-bold small">Mở gian hàng</div>
                                            <div class="x-small opacity-75">Bán món ngon của bạn</div>
                                        </div>
                                    </div>
                                    <i class="bi bi-chevron-right"></i>
                                </a>

                                @if (!User.IsInRole("Shipper"))
                                {
                                    <a asp-action="ApplyAsShipper" class="btn-earn btn-earn-shipper">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box me-3"><i class="bi bi-bicycle"></i></div>
                                            <div class="text-start">
                                                <div class="fw-bold small">Đăng ký Shipper</div>
                                                <div class="x-small opacity-75">Giao hàng linh hoạt</div>
                                            </div>
                                        </div>
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --food-orange: #ff7e5f;
        --food-green: #2ecc71;
        --food-blue: #3498db;
        --soft-gray: #f8fafc;
        --text-muted: #94a3b8;
    }

    body { font-family: 'Lexend', sans-serif; background: #fcfcfc; }

    /* Main Card Styling */
    .main-profile-card {
        background: #fff;
        border-radius: 30px;
        overflow: visible !important; /* PHẢI LÀ VISIBLE ĐỂ ICON KHÔNG BỊ CẮT */
        position: relative;
        margin-top: 60px; /* Thêm margin để không bị đè menu trên */
    }

    .profile-cover {
        height: 150px; /* Tăng nhẹ chiều cao để cân đối */
        background: linear-gradient(45deg, #ff7e5f, #feb47b);
        border-radius: 30px 30px 40px 40px;
    }

    /* Avatar */
    .avatar-wrapper {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: 110px;
        height: 110px;
    }

    .avatar-circle {
        width: 100%;
        height: 100%;
        background: #fff;
        border-radius: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: var(--food-orange);
        border: 4px solid #fff;
    }

    .status-indicator {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 18px;
        height: 18px;
        background: var(--food-green);
        border: 3px solid #fff;
        border-radius: 50%;
    }

    /* Form Styling */
    .label-small {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--text-muted);
        letter-spacing: 1px;
        margin-left: 10px;
        margin-bottom: 8px;
    }

    .input-readonly {
        background: var(--soft-gray);
        padding: 12px 20px;
        border-radius: 15px;
        color: #64748b;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .badge-lock { color: var(--text-muted); font-size: 0.8rem; }

    .form-control-food {
        background: var(--soft-gray);
        border: 2px solid transparent;
        border-radius: 15px;
        padding: 12px 20px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s;
    }

    .form-control-food:focus {
        background: #fff;
        border-color: var(--food-orange);
        box-shadow: 0 8px 20px rgba(255, 126, 95, 0.1);
        outline: none;
    }

    /* Action Sidebar Cards */
    .status-card, .earn-card {
        background: #fff;
        border-radius: 25px;
    }

    .role-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .badge-admin { background: #fee2e2; color: #ef4444; }
    .badge-seller { background: #fff7ed; color: #f97316; }
    .badge-shipper { background: #f0f9ff; color: #0ea5e9; }
    .badge-user { background: #f0fdf4; color: #22c55e; }

    /* Earn Buttons */
    .btn-earn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 15px;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s;
    }

    .btn-earn-seller { background: #f0fdf4; color: #166534; }
    .btn-earn-shipper { background: #eff6ff; color: #1e40af; }

    .btn-earn:hover { transform: translateX(8px); opacity: 0.9; }

    .icon-box {
        width: 40px; height: 40px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        background: rgba(255,255,255,0.6);
    }

    .btn-save-profile {
        background: linear-gradient(45deg, var(--food-orange), #feb47b);
        color: white;
        border: none;
        border-radius: 20px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

    .btn-save-profile:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(255, 126, 95, 0.4);
        color: white;
    }

    .text-orange { color: var(--food-orange); }
    .x-small { font-size: 0.7rem; }
    .text-danger-custom { font-size: 0.7rem; color: #ef4444; margin-top: 5px; display: block; }

    .alert-food-success { background: #dcfce7; color: #166534; }

</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btnUpdate = document.getElementById('btnUpdate');
            const form = document.getElementById('profileForm');

            // 1. Hiệu ứng Loading khi nhấn Save
            form.addEventListener('submit', function() {
                if ($(form).valid()) {
                    btnUpdate.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ĐANG LƯU...`;
                    btnUpdate.style.opacity = '0.8';
                    btnUpdate.style.pointerEvents = 'none';
                }
            });

            // 2. Tự động ẩn thông báo sau 5 giây
            setTimeout(() => {
                const alert = document.querySelector('.alert');
                if (alert) {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }
            }, 5000);

            // 3. Hover effect cho avatar
            const avatar = document.querySelector('.avatar-circle');
            avatar.addEventListener('mouseenter', () => {
                avatar.style.transform = 'scale(1.05) rotate(5deg)';
                avatar.style.transition = 'all 0.3s ease';
            });
            avatar.addEventListener('mouseleave', () => {
                avatar.style.transform = 'scale(1) rotate(0deg)';
            });
        });
    </script>
}