@model List<Daylifood.Models.Order>
@using Daylifood.Models
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    var totalOrders = Model.Count;
    var deliveredOrders = Model.Count(o => o.Status == OrderStatus.Delivered);
    var awaitingPaymentOrders = Model.Count(o => o.Status == OrderStatus.AwaitingPayment);

    static string BadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.AwaitingPayment => "bg-warning-subtle text-warning-emphasis",
        OrderStatus.Pending => "bg-info-subtle text-info-emphasis",
        OrderStatus.Confirmed => "bg-primary-subtle text-primary-emphasis",
        OrderStatus.Shipping => "bg-secondary-subtle text-secondary-emphasis",
        OrderStatus.Delivered => "bg-success-subtle text-success-emphasis",
        OrderStatus.Cancelled => "bg-danger-subtle text-danger-emphasis",
        _ => "bg-light text-dark"
    };
}

<div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Lịch sử đơn hàng</h1>
            <p class="text-muted mb-0">Theo dõi trạng thái đơn, thanh toán và quay lại chi tiết đơn hàng.</p>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            <div class="card border-0 shadow-sm rounded-4 px-3 py-2">
                <div class="small text-muted">Tổng đơn</div>
                <div class="fw-bold fs-4">@totalOrders</div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 px-3 py-2">
                <div class="small text-muted">Đã giao</div>
                <div class="fw-bold fs-4 text-success">@deliveredOrders</div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 px-3 py-2">
                <div class="small text-muted">Chờ thanh toán</div>
                <div class="fw-bold fs-4 text-warning-emphasis">@awaitingPaymentOrders</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
            <div class="display-6 mb-3">🛒</div>
            <h2 class="h5 fw-bold">Bạn chưa có đơn hàng nào</h2>
            <p class="text-muted">Khám phá thực đơn và đặt món đầu tiên của bạn ngay bây giờ.</p>
            <div>
                <a asp-controller="Home" asp-action="Index" class="btn btn-success rounded-pill px-4">Xem thực đơn</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var o in Model.OrderByDescending(x => x.CreatedAt))
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                                <div>
                                    <div class="small text-muted">Mã đơn</div>
                                    <div class="fw-bold fs-5">#@o.Id</div>
                                </div>
                                <div>
                                    <div class="small text-muted">Thời gian đặt</div>
                                    <div class="fw-semibold">@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                                <div>
                                    <div class="small text-muted">Trạng thái đơn</div>
                                    <span class="badge rounded-pill @BadgeClass(o.Status)">@o.Status.ToVietnamese()</span>
                                </div>
                                <div>
                                    <div class="small text-muted">Thanh toán</div>
                                    <div class="fw-semibold">@o.PaymentMethod.ToVietnamese()</div>
                                    <div class="small @(o.PaymentStatus == PaymentStatus.Paid ? "text-success" : o.PaymentStatus == PaymentStatus.Failed ? "text-danger" : "text-muted")">@o.PaymentStatus.ToVietnamese()</div>
                                </div>
                            </div>

                            <div class="row g-3 align-items-center">
                                <div class="col-md-7">
                                    <div class="small text-muted mb-1">Giao tới</div>
                                    <div class="fw-semibold">@o.DeliveryArea.Name</div>
                                    <div class="text-muted">@o.DeliveryAddress</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="small text-muted mb-1">Tổng tiền</div>
                                    <div class="fw-bold text-success fs-5">@o.TotalPrice.ToString("N0") đ</div>
                                </div>
                                <div class="col-md-3 text-md-end d-flex flex-wrap gap-2 justify-content-md-end">
                                    @if (o.PaymentMethod == PaymentMethod.VnPay && o.Status == OrderStatus.AwaitingPayment && o.PaymentStatus == PaymentStatus.Pending)
                                    {
                                        <a asp-controller="Payment" asp-action="CreateVnPayPayment" asp-route-orderId="@o.Id" class="btn btn-outline-primary rounded-pill">Thanh toán ngay</a>
                                    }
                                    <a asp-action="Detail" asp-route-id="@o.Id" class="btn btn-success rounded-pill">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
