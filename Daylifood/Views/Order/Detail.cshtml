@model Daylifood.Models.Order
@using Daylifood.Models
@{
    ViewData["Title"] = "Chi tiết đơn #" + Model.Id;
    int stepLevel = Model.Status switch
    {
        OrderStatus.AwaitingPayment => 1,
        OrderStatus.Pending => 2,
        OrderStatus.Confirmed => 3,
        OrderStatus.Shipping => 4,
        OrderStatus.Delivered => 5,
        OrderStatus.Cancelled => 1,
        _ => 1
    };

    static string BadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.AwaitingPayment => "bg-warning-subtle text-warning-emphasis",
        OrderStatus.Pending => "bg-info-subtle text-info-emphasis",
        OrderStatus.Confirmed => "bg-primary-subtle text-primary-emphasis",
        OrderStatus.Shipping => "bg-secondary-subtle text-secondary-emphasis",
        OrderStatus.Delivered => "bg-success-subtle text-success-emphasis",
        OrderStatus.Cancelled => "bg-danger-subtle text-danger-emphasis",
        _ => "bg-light text-dark"
    };

    var paymentIcon = Model.PaymentMethod == PaymentMethod.VnPay ? "bi-qr-code-scan" : "bi-cash-stack";
    var steps = new[]
    {
        new { Level = 1, Label = "Thanh toán", Icon = "bi-wallet2" },
        new { Level = 2, Label = "Chờ quán", Icon = "bi-shop" },
        new { Level = 3, Label = "Chờ shipper", Icon = "bi-check2-circle" },
        new { Level = 4, Label = "Đang giao", Icon = "bi-truck" },
        new { Level = 5, Label = "Hoàn tất", Icon = "bi-bag-check" }
    };
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-action="History" class="text-decoration-none fw-semibold"><i class="bi bi-arrow-left me-2"></i>Quay lại lịch sử đơn hàng</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <div class="text-muted small">Mã đơn hàng</div>
                    <h1 class="h3 fw-bold mb-2">#@Model.Id</h1>
                    <div class="text-muted">Đặt lúc @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="text-lg-end">
                    <span class="badge rounded-pill fs-6 @BadgeClass(Model.Status)">@Model.Status.ToVietnamese()</span>
                    <div class="small mt-2 @(Model.PaymentStatus == PaymentStatus.Paid ? "text-success" : Model.PaymentStatus == PaymentStatus.Failed ? "text-danger" : "text-muted")">
                        @Model.PaymentStatus.ToVietnamese()
                    </div>
                </div>
            </div>

            @if (Model.PaymentMethod == PaymentMethod.VnPay && Model.Status == OrderStatus.AwaitingPayment && Model.PaymentStatus == PaymentStatus.Pending)
            {
                <div class="alert alert-warning rounded-4 border-0 d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-bold mb-1">Đơn hàng đang chờ thanh toán VNPay</div>
                        <div class="small">Sau khi VNPay gửi IPN xác nhận thành công, đơn sẽ chuyển sang trạng thái chờ quán xác nhận.</div>
                    </div>
                    <a asp-controller="Payment" asp-action="CreateVnPayPayment" asp-route-orderId="@Model.Id" class="btn btn-outline-dark rounded-pill">Tiếp tục thanh toán</a>
                </div>
            }

            <div class="row g-4 mb-4">
                <div class="col-lg-8">
                    <div class="d-flex justify-content-between position-relative gap-2 flex-wrap mb-3">
                        <div class="progress position-absolute top-50 start-0 translate-middle-y w-100" style="height:4px; z-index:0;">
                            <div class="progress-bar bg-success" style="width:@((stepLevel - 1) * 25)%"></div>
                        </div>
                        @foreach (var item in steps)
                        {
                            <div class="text-center position-relative" style="z-index:1; width:90px;">
                                <div class="rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center @(stepLevel >= item.Level ? "bg-success text-white" : "bg-light text-muted")" style="width:46px;height:46px;">
                                    <i class="bi @item.Icon"></i>
                                </div>
                                <div class="small fw-semibold">@item.Label</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card border rounded-4 h-100 bg-light-subtle">
                        <div class="card-body">
                            <div class="small text-muted mb-1">Thanh toán</div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                                    <i class="bi @paymentIcon text-success fs-4"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">@Model.PaymentMethod.ToVietnamese()</div>
                                    <div class="small text-muted">@Model.PaymentStatus.ToVietnamese()</div>
                                    @if (Model.PaidAt.HasValue)
                                    {
                                        <div class="small text-success">Thanh toán lúc @Model.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card border rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-2">Địa chỉ giao hàng</div>
                            <div class="fw-bold mb-1">@Model.DeliveryArea.Name</div>
                            <div>@Model.DeliveryAddress</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-2">Thông tin thanh toán</div>
                            <div><strong>Phương thức:</strong> @Model.PaymentMethod.ToVietnamese()</div>
                            <div><strong>Trạng thái:</strong> @Model.PaymentStatus.ToVietnamese()</div>
                            @if (!string.IsNullOrWhiteSpace(Model.PaymentGatewayTransactionNo))
                            {
                                <div><strong>Mã giao dịch cổng thanh toán:</strong> @Model.PaymentGatewayTransactionNo</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Món ăn</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Product.Name</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("N0") đ</td>
                                <td class="text-end fw-semibold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng</td>
                            <td class="text-end fw-bold text-success fs-5">@Model.TotalPrice.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
